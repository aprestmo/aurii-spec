{
  "name": "aurii",
  "version": "0.1.0",
  "private": true,
  "description": "Aurii — Declarative Runtime for Structured Knowledge",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "@turf/bbox": "^7.2.0",
    "@turf/simplify": "^7.2.0",
    "fflate": "^0.8.2",
    "yaml": "^2.7.1"
  },
  "scripts": {
    "build": "bun run --filter='*' build",
    "test": "bun run --filter='@aurii/core' test && bun run --filter='@aurii/sdk' test && bun run --filter='@aurii/studio' test && bun run --filter='@aurii/geo' test",
    "lint": "bun run --filter='*' lint",
    "typecheck": "bun run --filter='*' typecheck",
    "dev": "bun run --filter='@aurii/core' dev & bun run --filter='@aurii/studio' dev",
    "serve": "bun run --filter='@aurii/core' serve",
    "fetch:norwegian-geo": "bun run demo/norwegian-geo/scripts/fetch.ts",
    "fetch:historical-norwegian-geo": "bun run demo/norwegian-geo/core/historical/fetch-historical.ts",
    "fetch:ssb-identifiers-norwegian-geo": "bun run demo/norwegian-geo/core/historical/fetch-ssb-identifiers.ts",
    "build:municipality-enrichment": "bun run demo/norwegian-geo/core/historical/build-enrichment.ts",
    "validate:historical-norwegian-geo": "bun run demo/norwegian-geo/core/historical/validate.ts",
    "import:norwegian-geo": "bun run demo/norwegian-geo/scripts/import.ts",
    "build:geodata": "bun run demo/norwegian-geo/geodata/scripts/build-boundaries.ts"
  }
}
