{
  "name": "aurii",
  "version": "0.1.0",
  "private": true,
  "description": "Aurii — Declarative Runtime for Structured Knowledge",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "test": "bun run --filter='@aurii/core' test && bun run --filter='@aurii/sdk' test && bun run --filter='@aurii/studio' test && bun run --filter='@aurii/geo' test",
    "lint": "bun run --filter='*' lint",
    "typecheck": "bun run --filter='*' typecheck",
    "dev": "bun run --filter='@aurii/core' dev & bun run --filter='@aurii/studio' dev",
    "serve": "bun run --filter='@aurii/core' serve",
    "fetch:norwegian-geo": "bun run packages/core/scripts/fetch-norwegian-geo.ts",
    "fetch:historical-norwegian-geo": "bun run demo/norwegian-geo/historical/fetch-historical.ts",
    "build:municipality-enrichment": "bun run demo/norwegian-geo/historical/build-enrichment.ts",
    "validate:historical-norwegian-geo": "bun run demo/norwegian-geo/historical/validate.ts",
    "import:norwegian-geo": "bun run packages/core/scripts/import-norwegian-geo.ts"
  }
}
