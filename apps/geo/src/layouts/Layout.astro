---
import "@/styles/starwind.css";
import { ThemeToggle } from "@/components/starwind/theme-toggle";
import { isHomePage, url } from "../lib/base";

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath } = Astro.props;

const siteName = "Aurii Geo";
const fullTitle = `${title} — ${siteName}`;
const defaultDescription =
  "Aurii Geo er en demo som viser hvordan offentlig referansedata importeres, valideres, kobles og eksponeres som strukturert kunnskap i Aurii.";
const metaDescription = description ?? defaultDescription;

const siteUrl = Astro.site?.href?.replace(/\/$/, "") ?? "";
const canonicalUrl = canonicalPath !== undefined ? `${siteUrl}${url(canonicalPath)}` : Astro.url.href;

const onHome = isHomePage(Astro.url.pathname);

const homeNavItems = [
  { label: "Kom i gang", href: url("#kom-i-gang") },
  { label: "Datasett", href: url("#datasett") },
  { label: "Fylker", href: url("#fylker") },
  { label: "Spørringer", href: url("#sporringer") },
];

const siteNavItems = [
  { label: "Forside", href: url("") },
  { label: "Historikk", href: url("historikk") },
  { label: "Skoler", href: url("skoler") },
  { label: "Barnehager", href: url("barnehager") },
  { label: "Sykehus", href: url("sykehus") },
  { label: "Helligdager", href: url("helligdager") },
];

const navItems = onHome ? homeNavItems : siteNavItems;

const githubUrl = "https://github.com/aprestmo/aurii";
const docsUrl = "https://github.com/aprestmo/aurii/blob/main/docs/REFERENCE_DEMO.md";
const version = "0.1.0";
---

<!doctype html>
<html lang="nb">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <link rel="icon" href={url("favicon.svg")} type="image/svg+xml" />
    {siteUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    {siteUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta property="og:site_name" content={siteName} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <script is:inline>
      function initTheme() {
        const colorTheme = localStorage.getItem("colorTheme");
        if (!colorTheme) {
          if (window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
            localStorage.setItem("colorTheme", "dark");
          } else {
            document.documentElement.classList.remove("dark");
            localStorage.setItem("colorTheme", "light");
          }
        } else {
          if (colorTheme === "dark") {
            document.documentElement.classList.add("dark");
          } else if (colorTheme === "light") {
            document.documentElement.classList.remove("dark");
          } else if (colorTheme === "system") {
            const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
            document.documentElement.classList.toggle("dark", prefersDark);
          }
        }
      }

      initTheme();
      document.addEventListener("astro:after-swap", initTheme);
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-background focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:shadow-md focus:ring-2 focus:ring-outline"
    >
      Hopp til hovedinnhold
    </a>
    <header class="sticky top-0 z-50 border-b border-border bg-background/80 backdrop-blur supports-[backdrop-filter]:bg-background/60">
      <div class="mx-auto max-w-6xl px-4 sm:px-6">
        <div class="flex items-center justify-between gap-6 py-4 sm:py-5">
          <a href={url("")} class="group flex min-w-0 items-center gap-3 rounded-md focus:outline-none focus-visible:ring-2 focus-visible:ring-outline">
            <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-md bg-primary text-sm font-bold text-primary-foreground">
              A
            </span>
            <span class="min-w-0">
              <span class="block font-semibold tracking-tight group-hover:text-primary">Aurii Geo</span>
              <span class="block truncate text-xs text-muted-foreground">Offentlig referansedata</span>
            </span>
          </a>

          <nav aria-label="Hovednavigasjon" class="hidden items-center gap-1 md:flex">
            {navItems.map((item) => (
              <a
                href={item.href}
                class="rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
              >
                {item.label}
              </a>
            ))}
          </nav>

          <ThemeToggle size="sm" ariaLabel="Bytt mellom lys og mørk modus" />
        </div>

        <nav aria-label="Seksjonsnavigasjon" class="-mx-4 flex gap-1 overflow-x-auto border-t border-border/60 px-4 py-2 md:hidden">
          {navItems.map((item) => (
            <a
              href={item.href}
              class="shrink-0 rounded-md px-3 py-1.5 text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-foreground focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main id="main-content" class="mx-auto max-w-6xl px-4 py-10 sm:px-6 sm:py-12">
      <slot />
    </main>

    <footer class="border-t border-border bg-muted/30">
      <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          <div>
            <p class="font-medium">Datakilder</p>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              Kartverket, Bring, SSB, UDIR og Brønnøysundregistrene. Dataene er importert som strukturerte
              datasett og koblet sammen i Aurii.
            </p>
          </div>
          <div>
            <p class="font-medium">Drevet av Aurii</p>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              Dette nettstedet er generert fra strukturerte datasett i Aurii — en deklarativ runtime for
              strukturert kunnskap. Sider, tabeller og relasjoner bygges fra importert offentlig data.
            </p>
          </div>
          <div>
            <p class="font-medium">Lenker</p>
            <ul class="mt-2 space-y-1.5 text-sm">
              <li>
                <a
                  href={githubUrl}
                  class="text-muted-foreground transition-colors hover:text-foreground focus:outline-none focus-visible:ring-2 focus-visible:ring-outline rounded-sm"
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  GitHub
                </a>
              </li>
              <li>
                <a
                  href={docsUrl}
                  class="text-muted-foreground transition-colors hover:text-foreground focus:outline-none focus-visible:ring-2 focus-visible:ring-outline rounded-sm"
                  rel="noopener noreferrer"
                  target="_blank"
                >
                  Referansedemo-dokumentasjon
                </a>
              </li>
            </ul>
          </div>
        </div>
        <div class="mt-8 flex flex-col gap-2 border-t border-border pt-6 text-xs text-muted-foreground sm:flex-row sm:items-center sm:justify-between">
          <p>Aurii Geo · Norsk offentlig referansedata</p>
          <p>v{version} · Bygget fra importert referansedata</p>
        </div>
      </div>
    </footer>

    <script>
      document.addEventListener("click", (event) => {
        const button = (event.target as HTMLElement).closest<HTMLButtonElement>(".show-more-btn");
        if (!button) return;

        const listId = button.getAttribute("data-show-more-for");
        if (!listId) return;

        document
          .querySelectorAll<HTMLElement>(`[data-show-more-list="${listId}"] [data-show-more-hidden]`)
          .forEach((row) => {
            row.classList.remove("hidden");
            row.removeAttribute("data-show-more-hidden");
          });

        const status = document.querySelector<HTMLElement>(`[data-show-more-status="${listId}"]`);
        if (status) {
          status.textContent = status.dataset.showMoreComplete ?? status.textContent;
        }

        button.remove();
        document.dispatchEvent(new CustomEvent("show-more:revealed", { detail: { listId } }));
      });

      document.addEventListener("click", (event) => {
        const button = (event.target as HTMLElement).closest<HTMLButtonElement>(".copy-query-btn");
        if (!button || button.dataset.copyState === "success") return;

        const query = button.getAttribute("data-query");
        if (!query) return;

        navigator.clipboard.writeText(query).then(() => {
          const label = button.querySelector<HTMLElement>(".copy-query-label");
          const original = label?.textContent ?? "Kopier";
          button.dataset.copyState = "success";
          button.setAttribute("aria-label", "Spørring kopiert");
          if (label) label.textContent = "Kopiert!";
          window.setTimeout(() => {
            delete button.dataset.copyState;
            button.setAttribute("aria-label", "Kopier spørring");
            if (label) label.textContent = original;
          }, 2000);
        });
      });

      function parseSortValue(value: string, type: string): string | number {
        if (type === "number") {
          const parsed = Number.parseFloat(value.replace(/\s/g, "").replace(",", "."));
          return Number.isFinite(parsed) ? parsed : 0;
        }
        return value.toLocaleLowerCase("nb");
      }

      const SORT_ICON_UP =
        '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5 shrink-0"><path d="M12 5l0 14"/><path d="M18 11l-6 -6"/><path d="M6 11l6 -6"/></svg>';
      const SORT_ICON_DOWN =
        '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5 shrink-0"><path d="M12 5l0 14"/><path d="M18 13l-6 6"/><path d="M6 13l6 6"/></svg>';
      const SORT_ICON_NEUTRAL =
        '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5 shrink-0 opacity-0 transition-opacity group-hover:opacity-50"><path d="M8 9l4 -4l4 4"/><path d="M16 15l-4 4l-4 -4"/></svg>';

      function updateSortIndicators(table: HTMLTableElement) {
        const headers = table.tHead?.rows[0]?.cells;
        if (!headers) return;

        Array.from(headers).forEach((header) => {
          const indicator = header.querySelector<HTMLElement>("[data-sort-indicator]");
          if (!indicator) return;
          const sort = header.getAttribute("aria-sort");
          if (sort === "ascending") {
            indicator.innerHTML = SORT_ICON_UP;
            indicator.className = "inline-flex text-muted-foreground";
          } else if (sort === "descending") {
            indicator.innerHTML = SORT_ICON_DOWN;
            indicator.className = "inline-flex text-muted-foreground";
          } else {
            indicator.innerHTML = SORT_ICON_NEUTRAL;
            indicator.className = "inline-flex text-muted-foreground";
          }
        });
      }

      function sortTable(table: HTMLTableElement, columnIndex: number, type: string, ascending: boolean) {
        const tbody = table.tBodies[0];
        if (!tbody) return;

        const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>("tr"));
        const multiplier = ascending ? 1 : -1;

        rows.sort((a, b) => {
          const aCell = a.cells[columnIndex];
          const bCell = b.cells[columnIndex];
          const aValue = parseSortValue(aCell?.dataset.sortValue ?? aCell?.textContent?.trim() ?? "", type);
          const bValue = parseSortValue(bCell?.dataset.sortValue ?? bCell?.textContent?.trim() ?? "", type);

          if (typeof aValue === "number" && typeof bValue === "number") {
            return (aValue - bValue) * multiplier;
          }

          return String(aValue).localeCompare(String(bValue), "nb") * multiplier;
        });

        rows.forEach((row) => tbody.appendChild(row));
        updateSortIndicators(table);
      }

      function initSortableTables(root: ParentNode = document) {
        root.querySelectorAll<HTMLTableElement>("table[data-sortable]").forEach((table) => {
          if (table.dataset.sortableInit === "true") return;
          table.dataset.sortableInit = "true";

          const headers = table.tHead?.rows[0]?.cells;
          if (!headers) return;

          Array.from(headers).forEach((header, index) => {
            const type = header.dataset.sortType ?? "text";
            if (type === "none") return;

            header.classList.add("cursor-pointer", "select-none", "hover:text-foreground", "group");
            header.setAttribute("aria-sort", "none");
            header.setAttribute("tabindex", "0");
            header.setAttribute("role", "columnheader");

            if (!header.querySelector("[data-sort-indicator]")) {
              const label = header.textContent?.trim() ?? "";
              header.textContent = "";
              const wrapper = document.createElement("span");
              wrapper.className = "inline-flex items-center gap-1.5";
              const labelSpan = document.createElement("span");
              labelSpan.textContent = label;
              const indicator = document.createElement("span");
              indicator.dataset.sortIndicator = "true";
              indicator.setAttribute("aria-hidden", "true");
              wrapper.append(labelSpan, indicator);
              header.append(wrapper);
            }

            const activateSort = () => {
              const ascending = header.getAttribute("aria-sort") !== "ascending";
              Array.from(headers).forEach((h) => {
                if (h !== header) h.setAttribute("aria-sort", "none");
              });
              header.setAttribute("aria-sort", ascending ? "ascending" : "descending");
              sortTable(table, index, type, ascending);
            };

            header.addEventListener("click", activateSort);
            header.addEventListener("keydown", (event) => {
              if (event.key === "Enter" || event.key === " ") {
                event.preventDefault();
                activateSort();
              }
            });
          });

          const defaultSort = table.dataset.defaultSort;
          if (defaultSort) {
            const [columnIndex, direction] = defaultSort.split(":");
            const index = Number(columnIndex);
            const header = headers[index];
            if (header && header.dataset.sortType !== "none") {
              const ascending = direction !== "desc";
              Array.from(headers).forEach((h, i) => {
                h.setAttribute("aria-sort", i === index ? (ascending ? "ascending" : "descending") : "none");
              });
              sortTable(table, index, header.dataset.sortType ?? "text", ascending);
            }
          } else {
            updateSortIndicators(table);
          }
        });
      }

      function initTableFilters(root: ParentNode = document) {
        root.querySelectorAll<HTMLInputElement>("input[data-table-filter]").forEach((input) => {
          if (input.dataset.filterInit === "true") return;
          input.dataset.filterInit = "true";

          const tableId = input.getAttribute("data-table-filter");
          if (!tableId) return;

          const table = document.getElementById(tableId) as HTMLTableElement | null;
          if (!table?.tBodies[0]) return;

          const rows = Array.from(table.tBodies[0].querySelectorAll<HTMLTableRowElement>("tr"));

          input.addEventListener("input", () => {
            const query = input.value.trim().toLocaleLowerCase("nb");
            let visible = 0;

            rows.forEach((row) => {
              if (row.hasAttribute("data-show-more-hidden")) return;
              const text = row.textContent?.toLocaleLowerCase("nb") ?? "";
              const match = query === "" || text.includes(query);
              row.classList.toggle("hidden", !match);
              row.classList.toggle("bg-primary/5", match && query !== "");
              if (match) visible++;
            });

            const status = document.querySelector<HTMLElement>(`[data-filter-status="${tableId}"]`);
            if (status) {
              status.textContent =
                query === ""
                  ? (status.dataset.filterDefault ?? "")
                  : `${visible} treff`;
            }
          });
        });
      }

      initSortableTables();
      initTableFilters();
      document.addEventListener("astro:after-swap", () => {
        initSortableTables();
        initTableFilters();
      });
    </script>
  </body>
</html>
