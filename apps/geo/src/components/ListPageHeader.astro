---
interface Props {
  title: string;
  description: string;
  hint?: string;
}

const { title, description, hint } = Astro.props;
---

<header class="mb-8">
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{title}</h1>
  <p class="mt-3 max-w-2xl text-base leading-relaxed text-muted-foreground">{description}</p>
  {hint && (
    <p class="mt-3 max-w-2xl rounded-lg border border-border/70 bg-muted/20 px-4 py-3 text-sm leading-relaxed text-muted-foreground">
      {hint}
    </p>
  )}
</header>
