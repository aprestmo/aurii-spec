---
import { Card, CardContent } from "@/components/starwind/card";
import { url } from "@/lib/base";
import type { AdministrativeFlow } from "@/lib/historical-flow";
import { formatPeriod } from "@/lib/historical-data";

interface Props {
  flow: AdministrativeFlow;
  title?: string;
}

const { flow, title = "Flytskjema" } = Astro.props;

const nodeById = new Map(flow.nodes.map((n) => [n.id, n]));

function nodeSubtitle(node: (typeof flow.nodes)[number]): string {
  const parts: string[] = [];
  if (node.number) parts.push(node.number);
  const period = formatPeriod(node.validFrom, node.validTo);
  if (period !== "—") parts.push(period);
  return parts.join(" · ");
}

function edgesBetween(fromLayer: string[], toLayer: string[]) {
  return flow.edges.filter(
    (e) => fromLayer.includes(e.from) && toLayer.includes(e.to),
  );
}
---

{flow.layers.length > 0 && (
  <section class="mb-10" aria-labelledby="flow-heading">
    <h2 id="flow-heading" class="mb-2 text-xl font-semibold tracking-tight">{title}</h2>
    <p class="mb-6 text-sm text-muted-foreground">
      Pilene viser administrative endringer over tid — eldste enheter til venstre, dagens enhet til høyre.
    </p>

    <Card class="border-border/80 overflow-x-auto">
      <CardContent class="min-w-[min(100%,640px)] p-4 sm:p-6">
        <div
          class="admin-flow"
          style={`--flow-layers: ${flow.layers.length}`}
          role="img"
          aria-label={`Flytskjema med ${flow.nodes.length} enheter og ${flow.edges.length} endringer`}
        >
          {flow.layers.map((layer, layerIndex) => (
            <div class="admin-flow__layer" data-layer={layerIndex}>
              <div class="admin-flow__nodes">
                {layer.map((nodeId) => {
                  const node = nodeById.get(nodeId)!;
                  const isFocus = nodeId === flow.focusNodeId;
                  const content = (
                    <div
                      class:list={[
                        "admin-flow__node",
                        node.isCurrent && "admin-flow__node--current",
                        isFocus && "admin-flow__node--focus",
                      ]}
                    >
                      {node.coatOfArms && (
                        <img
                          src={url(node.coatOfArms.localPath.replace(/^\//, ""))}
                          alt=""
                          width="36"
                          height="44"
                          class="admin-flow__node-coat"
                          loading="lazy"
                        />
                      )}
                      <p class="admin-flow__node-name">{node.name}</p>
                      {nodeSubtitle(node) && (
                        <p class="admin-flow__node-meta">{nodeSubtitle(node)}</p>
                      )}
                      {node.isCurrent && (
                        <span class="admin-flow__node-badge">Dagens</span>
                      )}
                    </div>
                  );
                  return node.link ? (
                    <a href={url(node.link)} class="admin-flow__node-link">
                      {content}
                    </a>
                  ) : (
                    <div class="admin-flow__node-wrap">{content}</div>
                  );
                })}
              </div>

              {layerIndex < flow.layers.length - 1 && (
                <div class="admin-flow__connector" aria-hidden="true">
                  {edgesBetween(layer, flow.layers[layerIndex + 1]!).map((edge) => (
                    <div class="admin-flow__edge" data-edge={edge.id}>
                      <span class="admin-flow__edge-line" />
                      <span class="admin-flow__edge-label">{edge.label}</span>
                      <span class="admin-flow__edge-arrow">→</span>
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))}
        </div>
      </CardContent>
    </Card>
  </section>
)}

<style>
  .admin-flow {
    display: flex;
    align-items: stretch;
    gap: 0;
    min-height: 8rem;
  }

  .admin-flow__layer {
    display: flex;
    align-items: center;
    flex: 1;
    min-width: 9rem;
  }

  .admin-flow__nodes {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1;
  }

  .admin-flow__node-link,
  .admin-flow__node-wrap {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .admin-flow__node-link:focus-visible .admin-flow__node {
    outline: 2px solid var(--color-outline);
    outline-offset: 2px;
  }

  .admin-flow__node {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-card);
    padding: 0.75rem 0.875rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .admin-flow__node-link:hover .admin-flow__node {
    border-color: color-mix(in srgb, var(--color-primary) 40%, var(--color-border));
    box-shadow: 0 1px 3px rgb(0 0 0 / 0.06);
  }

  .admin-flow__node--current {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 6%, var(--color-card));
  }

  .admin-flow__node--focus {
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 25%, transparent);
  }

  .admin-flow__node-coat {
    margin-bottom: 0.375rem;
    height: 2.25rem;
    width: auto;
  }

  .admin-flow__node-name {
    font-weight: 600;
    font-size: 0.875rem;
    line-height: 1.3;
  }

  .admin-flow__node-meta {
    margin-top: 0.25rem;
    font-size: 0.75rem;
    color: var(--color-muted-foreground);
    font-family: ui-monospace, monospace;
  }

  .admin-flow__node-badge {
    display: inline-block;
    margin-top: 0.375rem;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-primary);
  }

  .admin-flow__connector {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.5rem;
    padding: 0 0.5rem;
    min-width: 5rem;
    max-width: 7rem;
  }

  .admin-flow__edge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.125rem;
  }

  .admin-flow__edge-line {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--color-border);
  }

  .admin-flow__edge-label {
    font-size: 0.625rem;
    line-height: 1.2;
    text-align: center;
    color: var(--color-muted-foreground);
    max-width: 6.5rem;
  }

  .admin-flow__edge-arrow {
    font-size: 0.875rem;
    color: var(--color-muted-foreground);
    line-height: 1;
  }

  @media (max-width: 640px) {
    .admin-flow {
      flex-direction: column;
      align-items: stretch;
    }

    .admin-flow__layer {
      flex-direction: column;
      min-width: 0;
    }

    .admin-flow__connector {
      flex-direction: row;
      min-width: 0;
      max-width: none;
      padding: 0.5rem 0;
    }

    .admin-flow__edge {
      flex-direction: row;
      flex: 1;
      gap: 0.25rem;
    }

    .admin-flow__edge-line {
      width: auto;
      flex: 1;
      height: 1px;
    }

    .admin-flow__edge-arrow {
      transform: rotate(90deg);
    }
  }
</style>
