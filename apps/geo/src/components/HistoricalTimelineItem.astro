---
import { Badge } from "@/components/starwind/badge";
import { Card, CardDescription, CardHeader, CardTitle } from "@/components/starwind/card";
import HistoricalChangeBadge from "@/components/HistoricalChangeBadge.astro";
import { url } from "@/lib/base";
import {
  describeChangeAction,
  timelineStepYear,
} from "@/lib/historical-mobile-story";
import { formatPeriod, type TimelineStep } from "@/lib/historical-data";

export type TimelinePeriodMode = "range" | "end-year" | "number";

interface Props {
  step: TimelineStep;
  index: number;
  total: number;
  periodMode?: TimelinePeriodMode;
  currentStatusLabel?: string;
  showChangeType?: boolean;
}

const {
  step,
  index,
  total,
  periodMode = "range",
  currentStatusLabel = "Dagens enhet",
  showChangeType = true,
} = Astro.props;

const isLast = index === total - 1;
const isFirst = index === 0;
const yearMarker = timelineStepYear(step);
const changeAction = showChangeType ? describeChangeAction(step.changeType) : undefined;

function periodText(): string {
  if (step.isCurrent) {
    if (periodMode === "number") return "Gjeldende nummer";
    return currentStatusLabel;
  }
  if (periodMode === "end-year" && step.validTo) {
    return `opphørte ${step.validTo}`;
  }
  return formatPeriod(step.validFrom, step.validTo);
}

const period = periodText();
const numberLabel =
  step.entityType === "municipality" ? "kommunenr." : "fylkesnr.";
const metaParts = [
  step.number ? `${numberLabel} ${step.number}` : null,
  period !== "—" && !step.isCurrent ? period : null,
].filter(Boolean);

const cardClass = [
  "border-border/80 transition-colors",
  step.isCurrent && "border-primary/50 bg-primary/[0.03]",
  step.link && "hover:border-primary/40",
];
---

<li class="relative pb-6 last:pb-0">
  <div
    class:list={[
      "absolute -left-[1.875rem] top-1 z-10 hidden h-6 w-6 items-center justify-center rounded-full border-2 text-[10px] font-bold shadow-sm sm:flex",
      step.isCurrent
        ? "border-primary bg-primary text-primary-foreground"
        : isFirst
          ? "border-muted-foreground/80 bg-muted text-muted-foreground"
          : "border-border bg-card text-muted-foreground",
    ]}
    aria-hidden="true"
  >
    {index + 1}
  </div>

  {yearMarker && (
    <div
      class:list={[
        "absolute -left-[1.875rem] top-1.5 z-10 flex h-5 w-5 items-center justify-center rounded-full border-2 sm:hidden",
        step.isCurrent
          ? "border-primary bg-primary"
          : "border-border bg-card",
      ]}
      aria-hidden="true"
    >
      <span
        class:list={[
          "block h-1.5 w-1.5 rounded-full",
          step.isCurrent ? "bg-primary-foreground" : "bg-muted-foreground",
        ]}
      />
    </div>
  )}

  {!isLast && (
    <span
      class="absolute -left-[1.5rem] top-7 bottom-0 w-px bg-gradient-to-b from-border via-border/60 to-transparent"
      aria-hidden="true"
    />
  )}

  {
    step.link ? (
      <a
        href={url(step.link)}
        class="group block rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
      >
        <Card class:list={[cardClass, "group-hover:border-primary/40"]}>
          <CardHeader class="px-4 py-3.5 sm:px-5 sm:py-4">
            <div class="hidden flex-wrap items-center gap-1.5 sm:flex">
              {step.isCurrent ? (
                <Badge variant="primary" size="sm">
                  {periodMode === "number" ? "Gjeldende" : "Dagens"}
                </Badge>
              ) : (
                <Badge variant="outline" size="sm">
                  Historisk
                </Badge>
              )}
              {showChangeType && step.changeType && !step.isCurrent && (
                <HistoricalChangeBadge changeType={step.changeType} size="sm" />
              )}
            </div>

            <div class="flex items-start gap-3">
              {step.coatOfArms && (
                <img
                  src={url(step.coatOfArms.localPath.replace(/^\//, ""))}
                  alt=""
                  width="40"
                  height="50"
                  class="mt-0.5 h-9 w-auto shrink-0 sm:order-last sm:mt-0 sm:h-12"
                  loading="lazy"
                />
              )}

              <div class="min-w-0 flex-1">
                {yearMarker && (
                  <p
                    class:list={[
                      "mb-1 font-mono text-base font-semibold tabular-nums sm:hidden",
                      step.isCurrent ? "text-primary" : "text-foreground",
                    ]}
                  >
                    {yearMarker}
                  </p>
                )}

                <CardTitle class="text-base leading-snug sm:text-lg">
                  {step.name}
                </CardTitle>

                {changeAction && !step.isCurrent && (
                  <p class="mt-1 text-sm text-muted-foreground sm:hidden">{changeAction}</p>
                )}

                {step.isCurrent && (
                  <p class="mt-1 text-sm font-medium text-primary sm:hidden">
                    {periodMode === "number" ? "Gjeldende nummer" : currentStatusLabel}
                  </p>
                )}

                {metaParts.length > 0 && (
                  <CardDescription class="mt-1.5 text-sm text-muted-foreground">
                    {metaParts.join(" · ")}
                  </CardDescription>
                )}
              </div>
            </div>
          </CardHeader>
        </Card>
      </a>
    ) : (
      <Card class:list={cardClass}>
        <CardHeader class="px-4 py-3.5 sm:px-5 sm:py-4">
          <div class="hidden flex-wrap items-center gap-1.5 sm:flex">
            {step.isCurrent ? (
              <Badge variant="primary" size="sm">
                {periodMode === "number" ? "Gjeldende" : "Dagens"}
              </Badge>
            ) : (
              <Badge variant="outline" size="sm">
                Historisk
              </Badge>
            )}
            {showChangeType && step.changeType && !step.isCurrent && (
              <HistoricalChangeBadge changeType={step.changeType} size="sm" />
            )}
          </div>

          <div class="flex items-start gap-3">
            {step.coatOfArms && (
              <img
                src={url(step.coatOfArms.localPath.replace(/^\//, ""))}
                alt=""
                width="40"
                height="50"
                class="mt-0.5 h-9 w-auto shrink-0 sm:order-last sm:mt-0 sm:h-12"
                loading="lazy"
              />
            )}

            <div class="min-w-0 flex-1">
              {yearMarker && (
                <p
                  class:list={[
                    "mb-1 font-mono text-base font-semibold tabular-nums sm:hidden",
                    step.isCurrent ? "text-primary" : "text-foreground",
                  ]}
                >
                  {yearMarker}
                </p>
              )}

              <CardTitle class="text-base leading-snug sm:text-lg">{step.name}</CardTitle>

              {changeAction && !step.isCurrent && (
                <p class="mt-1 text-sm text-muted-foreground sm:hidden">{changeAction}</p>
              )}

              {step.isCurrent && (
                <p class="mt-1 text-sm font-medium text-primary sm:hidden">
                  {periodMode === "number" ? "Gjeldende nummer" : currentStatusLabel}
                </p>
              )}

              {metaParts.length > 0 && (
                <CardDescription class="mt-1.5 text-sm text-muted-foreground">
                  {metaParts.join(" · ")}
                </CardDescription>
              )}
            </div>
          </div>
        </CardHeader>
      </Card>
    )
  }
</li>
