---
import HistoricalChangeBadge from "@/components/HistoricalChangeBadge.astro";
import HistoricalEntityCard from "@/components/HistoricalEntityCard.astro";
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/starwind/card";
import { Separator } from "@/components/starwind/separator";
import type { AdministrativeFlow } from "@/lib/historical-flow";

interface Props {
  flow: AdministrativeFlow;
  title?: string;
  description?: string;
}

const {
  flow,
  title = "Administrative endringer",
  description = "Hvordan enheten utviklet seg over tid — eldste forgjengere til venstre, dagens enhet til høyre.",
} = Astro.props;

const nodeById = new Map(flow.nodes.map((n) => [n.id, n]));

function edgesBetween(fromLayer: string[], toLayer: string[]) {
  return flow.edges.filter(
    (e) => fromLayer.includes(e.from) && toLayer.includes(e.to),
  );
}

/** Chronological list of layer-to-layer transitions for mobile view. */
const transitions: Array<{
  edges: (typeof flow.edges)[number][];
  fromNodes: string[];
  toNodes: string[];
}> = [];

for (let i = 0; i < flow.layers.length - 1; i++) {
  const fromLayer = flow.layers[i]!;
  const toLayer = flow.layers[i + 1]!;
  const edges = edgesBetween(fromLayer, toLayer);
  if (edges.length > 0 || fromLayer.length > 0 || toLayer.length > 0) {
    transitions.push({ edges, fromNodes: fromLayer, toNodes: toLayer });
  }
}
---

{
  flow.layers.length > 0 && (
    <section class="mb-10" aria-labelledby="historical-flow-heading">
      <h2 id="historical-flow-heading" class="mb-2 text-xl font-semibold tracking-tight">
        {title}
      </h2>
      <p class="mb-6 max-w-2xl text-sm leading-relaxed text-muted-foreground">
        {description}
      </p>

      <Card class="border-border/80">
        <CardHeader class="border-b border-border/60 px-4 py-4 sm:px-6">
          <CardTitle class="text-base">Endringsforløp</CardTitle>
          <CardDescription class="mt-1">
            {flow.nodes.length} enheter · {flow.edges.length} endringer
          </CardDescription>
          <div class="mt-3 flex flex-wrap gap-2 text-xs">
            <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/40 bg-primary/5 px-2 py-0.5">
              <span class="h-2 w-2 rounded-full bg-primary" aria-hidden="true" />
              Dagens enhet
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full border border-border px-2 py-0.5">
              <span class="h-2 w-2 rounded-full border border-muted-foreground" aria-hidden="true" />
              Historisk enhet
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full border border-dashed border-border px-2 py-0.5">
              <span class="h-2 w-2 rounded-full border border-dashed border-muted-foreground" aria-hidden="true" />
              Usikker kobling
            </span>
          </div>
        </CardHeader>

        <CardContent class="p-4 sm:p-6">
          {/* Desktop: horizontal layer flow */}
          <div
            class="hidden md:flex md:items-stretch md:gap-0"
            role="img"
            aria-label={`Flytskjema med ${flow.nodes.length} enheter og ${flow.edges.length} endringer`}
          >
            {flow.layers.map((layer, layerIndex) => {
              const nextLayer = flow.layers[layerIndex + 1];
              return (
                <div class="flex min-w-0 flex-1 items-stretch">
                  <div class="flex min-w-[9rem] flex-1 flex-col justify-center gap-3">
                    {layer.map((nodeId) => {
                      const node = nodeById.get(nodeId)!;
                      return (
                        <HistoricalEntityCard
                          name={node.name}
                          number={node.number}
                          validFrom={node.validFrom}
                          validTo={node.validTo}
                          isCurrent={node.isCurrent}
                          isFocus={nodeId === flow.focusNodeId}
                          isUncertain={!node.link && !node.isCurrent}
                          link={node.link}
                          coatOfArms={node.coatOfArms}
                          compact
                        />
                      );
                    })}
                  </div>

                  {nextLayer && (
                    <div class="flex w-16 shrink-0 flex-col items-center justify-center gap-2 px-1">
                      <Separator orientation="vertical" class="h-full min-h-[3rem] flex-1" />
                      <div class="flex flex-col items-center gap-1.5">
                        {edgesBetween(layer, nextLayer).map((edge) => (
                          <div class="flex flex-col items-center gap-0.5">
                            <HistoricalChangeBadge
                              changeType={edge.changeType}
                              year={edge.changeYear}
                              size="sm"
                            />
                            <span class="text-muted-foreground" aria-hidden="true">
                              →
                            </span>
                          </div>
                        ))}
                      </div>
                      <Separator orientation="vertical" class="h-full min-h-[3rem] flex-1" />
                    </div>
                  )}
                </div>
              );
            })}
          </div>

          {/* Mobile: vertical change list */}
          <ol class="space-y-4 md:hidden">
            {transitions.map((transition, tIndex) => (
              <li class="rounded-lg border border-border/70 bg-muted/10 p-3">
                <p class="mb-3 text-xs font-medium uppercase tracking-wide text-muted-foreground">
                  Steg {tIndex + 1}
                </p>
                <div class="space-y-3">
                  <div class="space-y-2">
                    {transition.fromNodes.map((nodeId) => {
                      const node = nodeById.get(nodeId)!;
                      return (
                        <HistoricalEntityCard
                          name={node.name}
                          number={node.number}
                          validFrom={node.validFrom}
                          validTo={node.validTo}
                          isCurrent={node.isCurrent}
                          isFocus={nodeId === flow.focusNodeId}
                          isUncertain={!node.link && !node.isCurrent}
                          link={node.link}
                          coatOfArms={node.coatOfArms}
                          compact
                        />
                      );
                    })}
                  </div>

                  {transition.edges.length > 0 && (
                    <div class="flex flex-wrap items-center gap-2 border-l-2 border-border pl-3">
                      {transition.edges.map((edge) => (
                        <HistoricalChangeBadge
                          changeType={edge.changeType}
                          year={edge.changeYear}
                          size="sm"
                        />
                      ))}
                      <span class="text-sm text-muted-foreground" aria-hidden="true">
                        ↓
                      </span>
                    </div>
                  )}

                  <div class="space-y-2">
                    {transition.toNodes.map((nodeId) => {
                      const node = nodeById.get(nodeId)!;
                      return (
                        <HistoricalEntityCard
                          name={node.name}
                          number={node.number}
                          validFrom={node.validFrom}
                          validTo={node.validTo}
                          isCurrent={node.isCurrent}
                          isFocus={nodeId === flow.focusNodeId}
                          isUncertain={!node.link && !node.isCurrent}
                          link={node.link}
                          coatOfArms={node.coatOfArms}
                          compact
                        />
                      );
                    })}
                  </div>
                </div>
              </li>
            ))}
          </ol>
        </CardContent>
      </Card>
    </section>
  )
}
