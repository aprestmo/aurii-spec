---
import { Button } from "@/components/starwind/button";
import { CardFooter } from "@/components/starwind/card";
import { INITIAL_LIST_SIZE } from "@/lib/show-more";

interface Props {
  listId: string;
  total: number;
  initial?: number;
  noun: string;
}

const { listId, total, initial = INITIAL_LIST_SIZE, noun } = Astro.props;
const hasMore = total > initial;
const statusText = `Viser de første ${initial} av ${total} ${noun}.`;
const completeText = `Viser alle ${total} ${noun}.`;
---

{
  hasMore && (
    <CardFooter class="flex flex-col items-start gap-3 border-t border-border/60 px-6 py-4 sm:flex-row sm:items-center sm:justify-between">
      <p
        class="text-sm text-muted-foreground"
        id={`show-more-status-${listId}`}
        data-show-more-status={listId}
        data-show-more-complete={completeText}
      >
        {statusText}
      </p>
      <Button
        type="button"
        variant="outline"
        size="sm"
        class="show-more-btn shrink-0"
        data-show-more-for={listId}
        aria-describedby={`show-more-status-${listId}`}
      >
        Vis alle {total} {noun}
      </Button>
    </CardFooter>
  )
}
