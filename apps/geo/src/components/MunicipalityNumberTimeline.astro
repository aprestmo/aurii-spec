---
import HistoricalTimeline from "@/components/HistoricalTimeline.astro";
import { buildMunicipalityNumberTimeline } from "@/lib/historical-data";

interface Props {
  municipalityId: string;
  embedded?: boolean;
}

const { municipalityId, embedded = false } = Astro.props;
const timeline = await buildMunicipalityNumberTimeline(municipalityId);
const showTimeline = timeline.length > 1;
---

{
  showTimeline && (
    <HistoricalTimeline
      steps={timeline}
      title="Kommunenummer over tid"
      description="Offisielle kommunenummer fra SSB Klass, inkludert rene nummerbytter ved fylkesreformer."
      headingId="number-timeline-heading"
      periodMode="number"
      currentStatusLabel="Gjeldende nummer"
      class={embedded ? "mb-0" : undefined}
    >
      <p slot="footer">
        Kilde:{" "}
        <a
          href="https://data.ssb.no/api/klass/v1/classifications/131"
          class="underline-offset-4 hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          SSB Klass — kommuneinndeling
        </a>
      </p>
    </HistoricalTimeline>
  )
}
