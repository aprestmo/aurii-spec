---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<header class="mb-10">
  <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{title}</h1>
  {Astro.slots.has("meta") && (
    <div class="mt-3 flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
      <slot name="meta" />
    </div>
  )}
</header>
