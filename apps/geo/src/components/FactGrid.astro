---
import { Card, CardContent } from "@/components/starwind/card";

export interface FactItem {
  label: string;
  value: string;
}

interface Props {
  facts: FactItem[];
}

const { facts } = Astro.props;
---

<div class="mb-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
  {
    facts.map((fact) => (
      <Card>
        <CardContent class="px-4 py-3">
          <div class="text-xs uppercase tracking-wide text-muted-foreground">{fact.label}</div>
          <div class="mt-1 text-lg font-semibold tabular-nums">{fact.value}</div>
        </CardContent>
      </Card>
    ))
  }
</div>
