---
import { Badge } from "@/components/starwind/badge";
import {
  Card,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/starwind/card";
import { url } from "@/lib/base";
import { formatPeriod } from "@/lib/historical-data";
import type { CoatOfArms } from "@/lib/historical-data";

interface Props {
  name: string;
  number?: string;
  validFrom?: number;
  validTo?: number;
  isCurrent?: boolean;
  isFocus?: boolean;
  isUncertain?: boolean;
  link?: string;
  coatOfArms?: CoatOfArms;
  compact?: boolean;
}

const {
  name,
  number,
  validFrom,
  validTo,
  isCurrent = false,
  isFocus = false,
  isUncertain = false,
  link,
  coatOfArms,
  compact = false,
} = Astro.props;

const period = formatPeriod(validFrom, validTo);
const meta = [number, period !== "—" ? period : null].filter(Boolean).join(" · ");

const cardClass = [
  "border-border/80 transition-colors",
  isCurrent && "border-primary/60 bg-primary/5",
  isFocus && "ring-2 ring-primary/20",
  isUncertain && "border-dashed",
];
---

{
  link ? (
    <a
      href={url(link)}
      class="group block rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
    >
      <Card class:list={[cardClass, "group-hover:border-primary/40"]}>
        <CardHeader class:list={[compact ? "px-4 py-3" : "px-4 py-4", "space-y-2"]}>
          <div class="flex items-start justify-between gap-3">
            <div class="min-w-0 flex-1">
              <div class="mb-1.5 flex flex-wrap items-center gap-1.5">
                {isCurrent && (
                  <Badge variant="primary" size="sm">
                    Dagens
                  </Badge>
                )}
                {isUncertain && !isCurrent && (
                  <Badge variant="ghost" size="sm">
                    Usikker kobling
                  </Badge>
                )}
              </div>
              <CardTitle class:list={[compact ? "text-sm" : "text-base", "leading-snug"]}>
                {name}
              </CardTitle>
              {meta && (
                <CardDescription class="mt-1 font-mono text-xs">{meta}</CardDescription>
              )}
            </div>
            {coatOfArms && (
              <img
                src={url(coatOfArms.localPath.replace(/^\//, ""))}
                alt=""
                width={compact ? 28 : 36}
                height={compact ? 34 : 44}
                class:list={[compact ? "h-8" : "h-10", "w-auto shrink-0"]}
                loading="lazy"
              />
            )}
          </div>
        </CardHeader>
      </Card>
    </a>
  ) : (
    <Card class:list={cardClass}>
      <CardHeader class:list={[compact ? "px-4 py-3" : "px-4 py-4", "space-y-2"]}>
        <div class="flex items-start justify-between gap-3">
          <div class="min-w-0 flex-1">
            <div class="mb-1.5 flex flex-wrap items-center gap-1.5">
              {isCurrent && (
                <Badge variant="primary" size="sm">
                  Dagens
                </Badge>
              )}
              {isUncertain && !isCurrent && (
                <Badge variant="ghost" size="sm">
                  Usikker kobling
                </Badge>
              )}
            </div>
            <CardTitle class:list={[compact ? "text-sm" : "text-base", "leading-snug"]}>
              {name}
            </CardTitle>
            {meta && (
              <CardDescription class="mt-1 font-mono text-xs">{meta}</CardDescription>
            )}
          </div>
          {coatOfArms && (
            <img
              src={url(coatOfArms.localPath.replace(/^\//, ""))}
              alt=""
              width={compact ? 28 : 36}
              height={compact ? 34 : 44}
              class:list={[compact ? "h-8" : "h-10", "w-auto shrink-0"]}
              loading="lazy"
            />
          )}
        </div>
      </CardHeader>
    </Card>
  )
}
