---
import Breadcrumb from "@/components/Breadcrumb.astro";
import HistoricalChangeBadge from "@/components/HistoricalChangeBadge.astro";
import HistoricalFlowCard from "@/components/HistoricalFlowCard.astro";
import HistoricalTimeline from "@/components/HistoricalTimeline.astro";
import PageHeader from "@/components/PageHeader.astro";
import Layout from "../../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent, CardDescription } from "@/components/starwind/card";
import { url } from "../../../lib/base";
import {
  buildCountyTimeline,
  loadHistoricalCounties,
} from "../../../lib/historical-data";
import { buildForwardFlow, hasFlowContent } from "../../../lib/historical-flow";

export async function getStaticPaths() {
  const counties = await loadHistoricalCounties();
  return counties.map((county) => ({
    params: { id: county.id },
  }));
}

const { id } = Astro.params;
const counties = await loadHistoricalCounties();
const county = counties.find((c) => c.id === id);
if (!county) {
  return Astro.redirect(url("historikk"));
}

const timeline = await buildCountyTimeline(county.id);
const flow = await buildForwardFlow(county.id, "county");
const showFlow = hasFlowContent(flow);
---

<Layout
  title={county.name}
  description={`Historikk for fylket ${county.name} — opphørte ${county.validTo ?? "ukjent"}.`}
  canonicalPath={`historikk/fylker/${county.id}`}
>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Historikk", href: url("historikk") },
      { label: county.name },
    ]}
  />

  <PageHeader title={county.name}>
    <div class="flex flex-wrap items-center gap-3">
      {county.countyNumber && (
        <span class="font-mono text-sm text-muted-foreground">{county.countyNumber}</span>
      )}
      {county.validTo && (
        <Badge variant="outline">Opphørte {county.validTo}</Badge>
      )}
      {county.changeType && (
        <HistoricalChangeBadge changeType={county.changeType} />
      )}
    </div>
  </PageHeader>

  <div class="mb-10 grid gap-8 lg:grid-cols-[200px_1fr]">
    {county.coatOfArms && (
      <Card class="border-border/80">
        <CardContent class="flex flex-col items-center gap-3 px-5 py-6">
          <img
            src={url(county.coatOfArms.localPath.replace(/^\//, ""))}
            alt={`Fylkesvåpen for ${county.name}`}
            width="120"
            height="140"
            class="h-auto w-full max-w-[120px]"
          />
          {county.coatOfArms.license && (
            <CardDescription class="text-center text-xs">
              {county.coatOfArms.license}
            </CardDescription>
          )}
        </CardContent>
      </Card>
    )}

    <dl class="grid gap-3 sm:grid-cols-2">
      <div>
        <dt class="text-sm text-muted-foreground">Administrasjonssenter</dt>
        <dd class="font-medium">{county.administrativeCenter ?? "—"}</dd>
      </div>
      <div>
        <dt class="text-sm text-muted-foreground">I dag en del av</dt>
        <dd class="font-medium">{county.todayPartOfNames.join(", ") || "—"}</dd>
      </div>
      {county.newCountyNumber && (
        <div>
          <dt class="text-sm text-muted-foreground">Nytt nummer</dt>
          <dd class="font-mono font-medium">{county.newCountyNumber}</dd>
        </div>
      )}
    </dl>
  </div>

  {showFlow && (
    <HistoricalFlowCard
      flow={flow}
      title="Veien til dagens fylke"
      description="Administrative endringer fra dette fylket frem til dagens inndeling — inkludert gjenopprettelser og sammenslåinger."
      entityKind="fylke"
    />
  )}

  <HistoricalTimeline
    steps={timeline}
    title="Utviklingslinje"
    description="Hvordan fylket endret seg — inkludert gjenopprettelser og sammenslåinger."
    headingId="county-timeline"
    periodMode="end-year"
    currentStatusLabel="Dagens fylke"
    showChangeType={false}
    entityKind="fylke"
  />
</Layout>
