---
import Breadcrumb from "@/components/Breadcrumb.astro";
import AdminFlowDiagram from "@/components/AdminFlowDiagram.astro";
import PageHeader from "@/components/PageHeader.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import Layout from "../../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent, CardDescription } from "@/components/starwind/card";
import { url } from "../../../lib/base";
import {
  buildMunicipalityTimeline,
  changeTypeLabel,
  formatPeriod,
  loadHistoricalMunicipalities,
} from "../../../lib/historical-data";
import { buildForwardFlow, hasFlowContent } from "../../../lib/historical-flow";

export async function getStaticPaths() {
  const municipalities = await loadHistoricalMunicipalities();
  return municipalities.map((mun) => ({
    params: { id: mun.id },
  }));
}

const { id } = Astro.params;
const municipalities = await loadHistoricalMunicipalities();
const municipality = municipalities.find((m) => m.id === id);
if (!municipality) {
  return Astro.redirect(url("historikk"));
}

const timeline = await buildMunicipalityTimeline(municipality.id);
const flow = await buildForwardFlow(municipality.id, "municipality");
const showFlow = hasFlowContent(flow);
---

<Layout
  title={municipality.name}
  description={`Historikk for ${municipality.name} (${municipality.municipalityNumber ?? "—"}) — ${formatPeriod(municipality.validFrom, municipality.validTo)}.`}
  canonicalPath={`historikk/kommuner/${municipality.id}`}
>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Historikk", href: url("historikk") },
      { label: municipality.name },
    ]}
  />

  <PageHeader title={municipality.name}>
  <div class="flex flex-wrap items-center gap-3">
    {municipality.municipalityNumber && (
      <span class="font-mono text-sm text-muted-foreground">{municipality.municipalityNumber}</span>
    )}
    <Badge variant="outline">{formatPeriod(municipality.validFrom, municipality.validTo)}</Badge>
    {municipality.changeType && (
      <Badge>{changeTypeLabel(municipality.changeType)}</Badge>
    )}
  </div>
  </PageHeader>

  <div class="mb-10 grid gap-8 lg:grid-cols-[200px_1fr]">
    {municipality.coatOfArms && (
      <Card class="border-border/80">
        <CardContent class="flex flex-col items-center gap-3 px-5 py-6">
          <img
            src={url(municipality.coatOfArms.localPath.replace(/^\//, ""))}
            alt={`Kommunevåpen for ${municipality.name}`}
            width="120"
            height="150"
            class="h-auto w-full max-w-[120px]"
          />
          {municipality.coatOfArms.license && (
            <CardDescription class="text-center text-xs">
              {municipality.coatOfArms.license}
            </CardDescription>
          )}
        </CardContent>
      </Card>
    )}

    <div class="space-y-4">
      <dl class="grid gap-3 sm:grid-cols-2">
        <div>
          <dt class="text-sm text-muted-foreground">Fylke i kilden</dt>
          <dd class="font-medium">{municipality.countyNameAtSource ?? "—"}</dd>
        </div>
        <div>
          <dt class="text-sm text-muted-foreground">Resultat</dt>
          <dd class="font-medium">{municipality.resultNames.join(", ") || "—"}</dd>
        </div>
        {municipality.notes && (
          <div class="sm:col-span-2">
            <dt class="text-sm text-muted-foreground">Merknad</dt>
            <dd>{municipality.notes}</dd>
          </div>
        )}
      </dl>

      {municipality.wikipediaUrl && (
        <p class="text-sm">
          <a
            href={municipality.wikipediaUrl}
            class="text-primary underline-offset-4 hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Wikipedia-artikkel →
          </a>
        </p>
      )}
    </div>
  </div>

  {showFlow && (
    <AdminFlowDiagram
      flow={flow}
      title="Flytskjema til dagens kommune"
    />
  )}

  <SectionHeading
    title="Historielinje"
    description="Utvikling over tid — fra denne kommunen til dagens tilhørighet."
  />

  <ol class="relative space-y-0 border-l border-border pl-6">
    {timeline.map((step, index) => (
      <li class="relative pb-8 last:pb-0">
        <span
          class:list={[
            "absolute -left-[1.625rem] flex h-5 w-5 items-center justify-center rounded-full border-2 text-[10px] font-bold",
            step.isCurrent
              ? "border-primary bg-primary text-primary-foreground"
              : "border-muted-foreground bg-background text-muted-foreground",
          ]}
        >
          {index + 1}
        </span>
        <Card class="border-border/80">
          <CardContent class="px-5 py-4">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                {step.link ? (
                  <a
                    href={url(step.link)}
                    class="text-lg font-semibold text-foreground underline-offset-4 hover:text-primary hover:underline"
                  >
                    {step.name}
                  </a>
                ) : (
                  <p class="text-lg font-semibold">{step.name}</p>
                )}
                <p class="mt-1 text-sm text-muted-foreground">
                  {step.number && <span class="font-mono">{step.number}</span>}
                  {step.number && (step.validFrom || step.validTo) && " · "}
                  {formatPeriod(step.validFrom, step.validTo)}
                  {step.isCurrent && " · Dagens kommune"}
                </p>
              </div>
              {step.coatOfArms && (
                <img
                  src={url(step.coatOfArms.localPath.replace(/^\//, ""))}
                  alt=""
                  width="48"
                  height="60"
                  class="h-12 w-auto"
                  loading="lazy"
                />
              )}
            </div>
            {step.changeType && !step.isCurrent && (
              <p class="mt-2 text-sm text-muted-foreground">
                {changeTypeLabel(step.changeType)}
              </p>
            )}
          </CardContent>
        </Card>
      </li>
    ))}
  </ol>
</Layout>
