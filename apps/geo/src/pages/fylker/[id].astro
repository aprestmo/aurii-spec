---
import Breadcrumb from "@/components/Breadcrumb.astro";
import AdminFlowDiagram from "@/components/AdminFlowDiagram.astro";
import EntityNav from "@/components/EntityNav.astro";
import ExploreLinks from "@/components/ExploreLinks.astro";
import FactGrid from "@/components/FactGrid.astro";
import SearchField from "@/components/SearchField.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ShowMoreFooter from "@/components/ShowMoreFooter.astro";
import TableScroll from "@/components/TableScroll.astro";
import Layout from "../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent } from "@/components/starwind/card";
import {
  Table,
  TableBody,
  TableCaption,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/starwind/table";
import { url } from "../../lib/base";
import { formatPopulation } from "@/lib/format";
import { getAdjacentCounties } from "@/lib/navigation";
import { INITIAL_LIST_SIZE } from "@/lib/show-more";
import {
  getCounty,
  getCountyStats,
  getMunicipalitiesByCounty,
  loadCounties,
} from "../../lib/data";
import { buildAncestryFlow, hasFlowContent } from "../../lib/historical-flow";
import { getWikiCurrentCounty } from "../../lib/historical-data";

export async function getStaticPaths() {
  const counties = await loadCounties();
  return counties.map((county) => ({
    params: { id: county.id },
  }));
}

const { id } = Astro.params;
const county = await getCounty(id!);
if (!county) {
  return Astro.redirect(url(""));
}

const municipalities = await getMunicipalitiesByCounty(id!);
const stats = await getCountyStats(id!);
const populationYear = county.populationYear ?? stats.populationYear;
const adjacent = await getAdjacentCounties(id!);
const ancestryFlow = await buildAncestryFlow(id!, "county");
const showAncestryFlow = hasFlowContent(ancestryFlow);
const wikiCounty = await getWikiCurrentCounty(id!);

const pageDescription = `${county.name} i Aurii Geo — ${stats.municipalityCount} kommuner, ${formatPopulation(stats.population)} innbyggere, og koblede skoler og barnehager.`;

const exploreLinks = [
  ...(stats.largestMunicipality
    ? [
        {
          title: stats.largestMunicipality.name,
          description: `Største kommune i ${county.name} med ${formatPopulation(stats.largestMunicipality.population)} innbyggere.`,
          href: url(`kommuner/${stats.largestMunicipality.id}`),
        },
      ]
    : []),
  {
    title: "Skoler i fylket",
    description: `${stats.schoolCount.toLocaleString("nb-NO")} skoler er koblet til kommuner i ${county.name}.`,
    href: url("skoler"),
  },
  {
    title: "Barnehager i fylket",
    description: `${stats.kindergartenCount.toLocaleString("nb-NO")} barnehager er koblet til kommuner i ${county.name}.`,
    href: url("barnehager"),
  },
];
---

<Layout title={county.name} description={pageDescription} canonicalPath={`fylker/${county.id}`}>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: county.name },
    ]}
  />

  <header class="mb-10 flex flex-wrap items-start justify-between gap-6">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{county.name}</h1>
      <div class="mt-3 flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
        Fylkesnummer <Badge variant="outline">{county.id}</Badge>
        · {stats.municipalityCount} kommune{stats.municipalityCount === 1 ? "" : "r"}
        {populationYear && (
          <>· Innbyggertall per 1.1.{populationYear} (SSB)</>
        )}
      </div>
    </div>
    {wikiCounty?.coatOfArms && (
      <img
        src={url(wikiCounty.coatOfArms.localPath.replace(/^\//, ""))}
        alt={`Fylkesvåpen for ${county.name}`}
        width="80"
        height="96"
        class="h-20 w-auto shrink-0"
        loading="lazy"
      />
    )}
  </header>

  <FactGrid
    facts={[
      { label: "Innbyggere", value: formatPopulation(stats.population) },
      { label: "Kommuner", value: String(stats.municipalityCount) },
      {
        label: "Skoler",
        value: String(stats.schoolCount),
        description: "Koblet via kommuner i fylket",
      },
      {
        label: "Barnehager",
        value: String(stats.kindergartenCount),
        description: "Koblet via kommuner i fylket",
      },
      ...(stats.largestMunicipality
        ? [
            {
              label: "Største kommune",
              value: `${stats.largestMunicipality.name} (${formatPopulation(stats.largestMunicipality.population)})`,
            },
          ]
        : []),
      ...(stats.smallestMunicipality &&
      stats.smallestMunicipality.id !== stats.largestMunicipality?.id
        ? [
            {
              label: "Minste kommune",
              value: `${stats.smallestMunicipality.name} (${formatPopulation(stats.smallestMunicipality.population)})`,
            },
          ]
        : []),
    ]}
  />

  {showAncestryFlow && (
    <AdminFlowDiagram
      flow={ancestryFlow}
      title="Historisk utvikling"
    />
  )}

  <section aria-labelledby="municipalities-heading">
    <SectionHeading
      id="municipalities-heading"
      title="Kommuner"
      description="Alle kommuner i fylket, koblet gjennom Aurii-relasjoner. Velg en kommune for postnummer, skoler og barnehager."
    />
    <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <SearchField
        id="municipality-filter"
        label="Søk i kommuner"
        placeholder="Søk etter navn eller kommunenummer…"
        class="max-w-sm"
        data-table-filter="municipality-table"
      />
      <p
        class="text-sm text-muted-foreground"
        data-filter-status="municipality-table"
        data-filter-default={`Viser ${municipalities.length} kommuner`}
        role="status"
        aria-live="polite"
      >
        Viser {municipalities.length} kommuner
      </p>
    </div>
    <Card class="border-border/80">
      <CardContent class="p-0">
        <TableScroll>
          <Table id="municipality-table" data-sortable>
            <TableCaption class="sr-only">
              Kommuner i {county.name}. Klikk på kolonneoverskrifter for å sortere.
            </TableCaption>
            <TableHeader>
              <TableRow class="hover:bg-transparent">
                <TableHead data-sort-type="text" class="w-24">Nr.</TableHead>
                <TableHead data-sort-type="text">Navn</TableHead>
                <TableHead data-sort-type="number" class="text-right">Innbyggere</TableHead>
              </TableRow>
            </TableHeader>
            <TableBody data-show-more-list="municipality-list">
              {municipalities.map((mun, index) => (
                <TableRow
                  class:list={["transition-colors hover:bg-muted/50", { hidden: index >= INITIAL_LIST_SIZE }]}
                  data-show-more-hidden={index >= INITIAL_LIST_SIZE ? "" : undefined}
                >
                  <TableCell class="font-mono text-xs text-muted-foreground" data-sort-value={mun.id}>
                    {mun.id}
                  </TableCell>
                  <TableCell>
                    <a
                      href={url(`kommuner/${mun.id}`)}
                      class="font-medium text-foreground underline-offset-4 hover:text-primary hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-outline rounded-sm"
                    >
                      {mun.name}
                    </a>
                  </TableCell>
                  <TableCell
                    class="text-right tabular-nums"
                    data-sort-value={String(mun.population ?? 0)}
                  >
                    {formatPopulation(mun.population)}
                  </TableCell>
                </TableRow>
              ))}
            </TableBody>
          </Table>
        </TableScroll>
      </CardContent>
      <ShowMoreFooter listId="municipality-list" total={municipalities.length} noun="kommuner" />
    </Card>
  </section>

  <ExploreLinks links={exploreLinks} />

  <EntityNav previous={adjacent.previous} next={adjacent.next} basePath="fylker" label="Fylke" />
</Layout>
