---
import Breadcrumb from "@/components/Breadcrumb.astro";
import EntityNav from "@/components/EntityNav.astro";
import FactGrid from "@/components/FactGrid.astro";
import PageHeader from "@/components/PageHeader.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ShowMoreFooter from "@/components/ShowMoreFooter.astro";
import Layout from "../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent } from "@/components/starwind/card";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/starwind/table";
import { url } from "../../lib/base";
import { formatPopulation } from "@/lib/format";
import { getAdjacentCounties } from "@/lib/navigation";
import { INITIAL_LIST_SIZE } from "@/lib/show-more";
import {
  getCounty,
  getCountyStats,
  getMunicipalitiesByCounty,
  loadCounties,
} from "../../lib/data";

export async function getStaticPaths() {
  const counties = await loadCounties();
  return counties.map((county) => ({
    params: { id: county.id },
  }));
}

const { id } = Astro.params;
const county = await getCounty(id!);
if (!county) {
  return Astro.redirect(url(""));
}

const municipalities = await getMunicipalitiesByCounty(id!);
const stats = await getCountyStats(id!);
const populationYear = county.populationYear ?? stats.populationYear;
const adjacent = await getAdjacentCounties(id!);

const pageDescription = `${county.name} i Aurii Geo — ${stats.municipalityCount} kommuner, ${formatPopulation(stats.population)} innbyggere, og koblede skoler og barnehager.`;
---

<Layout title={county.name} description={pageDescription} canonicalPath={`fylker/${county.id}`}>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: county.name },
    ]}
  />

  <PageHeader title={county.name}>
    <Fragment slot="meta">
      Fylkesnummer <Badge variant="outline">{county.id}</Badge>
      · {stats.municipalityCount} kommune{stats.municipalityCount === 1 ? "" : "r"}
      {populationYear && (
        <>
          · Innbyggertall per 1.1.{populationYear} (SSB)
        </>
      )}
    </Fragment>
  </PageHeader>

  <FactGrid
    facts={[
      { label: "Innbyggere", value: formatPopulation(stats.population) },
      { label: "Kommuner", value: String(stats.municipalityCount) },
      { label: "Skoler", value: String(stats.schoolCount) },
      { label: "Barnehager", value: String(stats.kindergartenCount) },
      ...(stats.largestMunicipality
        ? [
            {
              label: "Største kommune",
              value: `${stats.largestMunicipality.name} (${formatPopulation(stats.largestMunicipality.population)})`,
            },
          ]
        : []),
      ...(stats.smallestMunicipality &&
      stats.smallestMunicipality.id !== stats.largestMunicipality?.id
        ? [
            {
              label: "Minste kommune",
              value: `${stats.smallestMunicipality.name} (${formatPopulation(stats.smallestMunicipality.population)})`,
            },
          ]
        : []),
    ]}
  />

  <section aria-labelledby="municipalities-heading">
    <SectionHeading
      id="municipalities-heading"
      title="Kommuner"
      description="Alle kommuner knyttet til dette fylket gjennom Aurii-relasjoner. Klikk på en kommune for å se skoler, barnehager og postnummer."
    />
    <Card class="border-border/80">
      <CardContent class="p-0">
        <Table data-sortable>
          <TableHeader>
            <TableRow class="hover:bg-transparent">
              <TableHead data-sort-type="text" class="w-24">Nr.</TableHead>
              <TableHead data-sort-type="text">Navn</TableHead>
              <TableHead data-sort-type="number" class="text-right">Innbyggere</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody data-show-more-list="municipality-list">
            {municipalities.map((mun, index) => (
              <TableRow
                class:list={["transition-colors hover:bg-muted/50", { hidden: index >= INITIAL_LIST_SIZE }]}
                data-show-more-hidden={index >= INITIAL_LIST_SIZE ? "" : undefined}
              >
                <TableCell class="font-mono text-xs text-muted-foreground" data-sort-value={mun.id}>
                  {mun.id}
                </TableCell>
                <TableCell>
                  <a
                    href={url(`kommuner/${mun.id}`)}
                    class="font-medium text-foreground underline-offset-4 hover:text-primary hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-outline rounded-sm"
                  >
                    {mun.name}
                  </a>
                </TableCell>
                <TableCell
                  class="text-right tabular-nums"
                  data-sort-value={String(mun.population ?? 0)}
                >
                  {formatPopulation(mun.population)}
                </TableCell>
              </TableRow>
            ))}
          </TableBody>
        </Table>
      </CardContent>
      <ShowMoreFooter listId="municipality-list" total={municipalities.length} noun="kommuner" />
    </Card>
  </section>

  <EntityNav previous={adjacent.previous} next={adjacent.next} basePath="fylker" label="Fylke" />
</Layout>
