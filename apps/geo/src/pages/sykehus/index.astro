---
import ShowMoreFooter from "@/components/ShowMoreFooter.astro";
import Layout from "../../layouts/Layout.astro";
import { Card, CardContent } from "@/components/starwind/card";
import { url } from "../../lib/base";
import { INITIAL_LIST_SIZE } from "@/lib/show-more";
import { loadHospitals } from "../../lib/data";

const hospitals = (await loadHospitals()).sort((a, b) =>
  a.name.localeCompare(b.name, "nb"),
);
---

<Layout title="Sykehus">
  <p class="mb-3 text-sm">
    <a href={url("")} class="text-muted-foreground hover:text-foreground">← Referansedata</a>
  </p>
  <div class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight">Sykehus</h1>
    <p class="mt-2 text-muted-foreground">
      {hospitals.length} sykehus fra Brønnøysundregistrene (næringskode 86.10)
    </p>
  </div>

  <Card>
    <CardContent class="p-0">
      <ul class="divide-y divide-border" data-show-more-list="hospital-list">
        {hospitals.map((hospital, index) => (
          <li
            class:list={[{ hidden: index >= INITIAL_LIST_SIZE }]}
            data-show-more-hidden={index >= INITIAL_LIST_SIZE ? "" : undefined}
          >
            <a
              href={url(`sykehus/${hospital.id}`)}
              class="flex items-center justify-between px-4 py-3 transition hover:bg-accent/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
            >
              <span class="font-medium">{hospital.name}</span>
              <span class="font-mono text-xs text-muted-foreground">{hospital.id}</span>
            </a>
          </li>
        ))}
      </ul>
    </CardContent>
    <ShowMoreFooter listId="hospital-list" total={hospitals.length} noun="sykehus" />
  </Card>
</Layout>
