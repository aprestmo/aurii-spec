---
import Breadcrumb from "@/components/Breadcrumb.astro";
import ShowMoreFooter from "@/components/ShowMoreFooter.astro";
import Layout from "../../layouts/Layout.astro";
import { Card, CardContent } from "@/components/starwind/card";
import { url } from "../../lib/base";
import { INITIAL_LIST_SIZE } from "@/lib/show-more";
import { loadHospitals } from "../../lib/data";

const hospitals = (await loadHospitals()).sort((a, b) =>
  a.name.localeCompare(b.name, "nb"),
);
---

<Layout
  title="Sykehus"
  description={`${hospitals.length} sykehus fra Brønnøysundregistrene, importert og koblet i Aurii.`}
  canonicalPath="sykehus"
>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Sykehus" },
    ]}
  />

  <header class="mb-8">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Sykehus</h1>
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
      {hospitals.length} sykehus fra Brønnøysundregistrene (næringskode 86.10), importert som
      strukturerte entiteter i Aurii.
    </p>
  </header>

  <Card class="border-border/80">
    <CardContent class="p-0">
      <ul class="divide-y divide-border" data-show-more-list="hospital-list">
        {hospitals.map((hospital, index) => (
          <li
            class:list={[{ hidden: index >= INITIAL_LIST_SIZE }]}
            data-show-more-hidden={index >= INITIAL_LIST_SIZE ? "" : undefined}
          >
            <a
              href={url(`sykehus/${hospital.id}`)}
              class="flex items-center justify-between gap-4 px-4 py-3.5 transition-colors hover:bg-muted/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
            >
              <span class="min-w-0 font-medium">{hospital.name}</span>
              <span class="shrink-0 font-mono text-xs text-muted-foreground">{hospital.id}</span>
            </a>
          </li>
        ))}
      </ul>
    </CardContent>
    <ShowMoreFooter listId="hospital-list" total={hospitals.length} noun="sykehus" />
  </Card>
</Layout>
