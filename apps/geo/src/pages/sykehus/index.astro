---
import Breadcrumb from "@/components/Breadcrumb.astro";
import ExploreLinks from "@/components/ExploreLinks.astro";
import ListPageHeader from "@/components/ListPageHeader.astro";
import SearchField from "@/components/SearchField.astro";
import ShowMoreFooter from "@/components/ShowMoreFooter.astro";
import Layout from "../../layouts/Layout.astro";
import { Card, CardContent, CardDescription } from "@/components/starwind/card";
import { formatOrgNumber } from "@/lib/format";
import { url } from "../../lib/base";
import { INITIAL_SEARCH_LIST_SIZE } from "@/lib/show-more";
import { loadHospitals } from "../../lib/data";

const hospitals = (await loadHospitals()).sort((a, b) =>
  a.name.localeCompare(b.name, "nb"),
);
---

<Layout
  title="Sykehus"
  description={`${hospitals.length} sykehus fra Brønnøysundregistrene, importert og koblet til kommuner i Aurii.`}
  canonicalPath="sykehus"
>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Sykehus" },
    ]}
  />

  <ListPageHeader
    title="Sykehus"
    description={`${hospitals.length} sykehus fra Brønnøysundregistrene (næringskode 86.10), importert som strukturerte entiteter og koblet til kommune.`}
    hint="Sykehus er koblet til kommune — ikke direkte til fylke. Åpne et sykehus for å se hvilken kommune det tilhører, eller søk etter navn eller org.nr."
  />

  <div class="mb-6">
    <SearchField
      id="search"
      label="Søk etter sykehus"
      placeholder="Sykehusnavn eller org.nr.…"
    />
  </div>

  <Card class="border-border/80">
    <CardContent class="p-0">
      <ul id="hospital-list" class="divide-y divide-border" data-show-more-list="hospital-list">
        {hospitals.map((hospital, index) => (
          <li
            data-name={hospital.name.toLowerCase()}
            data-id={hospital.id}
            class:list={[{ hidden: index >= INITIAL_SEARCH_LIST_SIZE }]}
            data-show-more-hidden={index >= INITIAL_SEARCH_LIST_SIZE ? "" : undefined}
          >
            <a
              href={url(`sykehus/${hospital.id}`)}
              class="flex items-center justify-between gap-4 px-4 py-3.5 transition-colors hover:bg-muted/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
            >
              <span class="min-w-0 font-medium">{hospital.name}</span>
              <span class="shrink-0 font-mono text-xs text-muted-foreground">{formatOrgNumber(hospital.id)}</span>
            </a>
          </li>
        ))}
      </ul>
    </CardContent>
    <ShowMoreFooter
      listId="hospital-list"
      total={hospitals.length}
      initial={INITIAL_SEARCH_LIST_SIZE}
      noun="sykehus"
    />
    <CardDescription id="more-note" class="border-t border-border/60 px-4 py-3 text-sm" role="status" aria-live="polite">
      Viser de første {INITIAL_SEARCH_LIST_SIZE.toLocaleString("nb-NO")}. Bruk søk for å finne et bestemt sykehus.
    </CardDescription>
  </Card>

  <ExploreLinks
    class="mt-10"
    title="Relatert i demoen"
    description="Sykehus deles geografisk kontekst med andre datasett via kommune."
    links={[
      {
        title: "Utforsk geografisk",
        description: "Velg fylke og kommune for å se koblede datasett.",
        href: url("#fylker"),
      },
      {
        title: "Skoler og barnehager",
        description: "Andre UDIR-registre koblet til samme kommunemodell.",
        href: url("skoler"),
      },
    ]}
  />
</Layout>

<script is:inline define:vars={{ hospitals, base: import.meta.env.BASE_URL, initialCount: INITIAL_SEARCH_LIST_SIZE }}>
  function formatOrgNumber(value) {
    if (!value) return "—";
    const digits = String(value).replace(/\D/g, "");
    if (digits.length !== 9) return value;
    return `${digits.slice(0, 3)} ${digits.slice(3, 6)} ${digits.slice(6, 9)}`;
  }

  const input = document.getElementById("search");
  const list = document.getElementById("hospital-list");
  const note = document.getElementById("more-note");
  let showAllRevealed = false;

  document.addEventListener("show-more:revealed", (event) => {
    if (event.detail.listId === "hospital-list") {
      showAllRevealed = true;
      if (note) note.textContent = `Viser alle ${hospitals.length.toLocaleString("nb-NO")} sykehus.`;
    }
  });

  function renderHospitalItem(hospital) {
    const li = document.createElement("li");
    li.dataset.name = hospital.name.toLowerCase();
    li.dataset.id = hospital.id;
    const a = document.createElement("a");
    a.href = `${base}sykehus/${hospital.id}`;
    a.className =
      "flex items-center justify-between gap-4 px-4 py-3.5 transition-colors hover:bg-muted/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline";
    const name = document.createElement("span");
    name.className = "min-w-0 font-medium";
    name.textContent = hospital.name;
    const id = document.createElement("span");
    id.className = "shrink-0 font-mono text-xs text-muted-foreground";
    id.textContent = formatOrgNumber(hospital.id);
    a.append(name, id);
    li.append(a);
    return li;
  }

  input?.addEventListener("input", () => {
    const q = input.value.trim().toLowerCase();
    if (!list) return;

    if (!q) {
      list.innerHTML = "";
      const visible = showAllRevealed ? hospitals : hospitals.slice(0, initialCount);
      for (const hospital of visible) {
        list.append(renderHospitalItem(hospital));
      }
      if (note) {
        note.textContent = showAllRevealed
          ? `Viser alle ${hospitals.length.toLocaleString("nb-NO")} sykehus.`
          : `Viser de første ${initialCount.toLocaleString("nb-NO")}. Bruk søk for å finne et bestemt sykehus.`;
      }
      return;
    }

    list.innerHTML = "";
    const matches = hospitals.filter(
      (h) => h.name.toLowerCase().includes(q) || h.id.toLowerCase().includes(q),
    );

    for (const hospital of matches.slice(0, 200)) {
      list.append(renderHospitalItem(hospital));
    }

    if (note) {
      note.textContent =
        matches.length === 0
          ? "Ingen sykehus matcher søket."
          : `${matches.length.toLocaleString("nb-NO")} treff`;
    }
  });
</script>
