---
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import Layout from "../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent } from "@/components/starwind/card";
import { Table, TableBody, TableCell, TableRow } from "@/components/starwind/table";
import { url } from "../../lib/base";
import {
  getHospital,
  getMunicipality,
  loadHospitals,
} from "../../lib/data";

export async function getStaticPaths() {
  const hospitals = await loadHospitals();
  return hospitals.map((hospital) => ({
    params: { id: hospital.id },
  }));
}

const { id } = Astro.params;
const hospital = await getHospital(id!);
if (!hospital) {
  return Astro.redirect(url("sykehus"));
}

const municipality = await getMunicipality(hospital.municipalityId);

const pageDescription = `${hospital.name} — sykehus i ${municipality?.name ?? "Norge"}, importert fra Brønnøysundregistrene og koblet i Aurii.`;
---

<Layout title={hospital.name} description={pageDescription} canonicalPath={`sykehus/${hospital.id}`}>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Sykehus", href: url("sykehus") },
      { label: hospital.name },
    ]}
  />

  <header class="mb-10">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{hospital.name}</h1>
    <p class="mt-3 flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
      Org.nr. <Badge variant="outline">{hospital.id}</Badge>
      {municipality && (
        <>
          ·{" "}
          <a
            href={url(`kommuner/${municipality.id}`)}
            class="rounded-sm transition-colors hover:text-foreground focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
          >
            {municipality.name}
          </a>
        </>
      )}
    </p>
  </header>

  <section aria-labelledby="properties-heading">
    <SectionHeading
      id="properties-heading"
      title="Egenskaper"
      description="Strukturerte egenskaper importert fra Brønnøysundregistrene og validert mot Aurii-skjemaet for sykehus."
    />
    <Card class="border-border/80">
      <CardContent class="p-0">
        <Table>
          <TableBody>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Næringskode</TableCell>
              <TableCell class="text-right font-mono text-xs">{hospital.industryCode}</TableCell>
            </TableRow>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Beskrivelse</TableCell>
              <TableCell class="text-right font-medium">{hospital.industryDescription}</TableCell>
            </TableRow>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Kilde</TableCell>
              <TableCell class="text-right font-mono text-xs">{hospital.source}</TableCell>
            </TableRow>
          </TableBody>
        </Table>
      </CardContent>
    </Card>
  </section>
</Layout>
