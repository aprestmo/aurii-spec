---
import Breadcrumb from "@/components/Breadcrumb.astro";
import ExploreLinks from "@/components/ExploreLinks.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import Layout from "../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent } from "@/components/starwind/card";
import { Table, TableBody, TableCell, TableRow } from "@/components/starwind/table";
import { formatOrgNumber } from "@/lib/format";
import { url } from "../../lib/base";
import {
  getCounty,
  getHospital,
  getHospitalsByMunicipality,
  getMunicipality,
  loadHospitals,
} from "../../lib/data";

export async function getStaticPaths() {
  const hospitals = await loadHospitals();
  return hospitals.map((hospital) => ({
    params: { id: hospital.id },
  }));
}

const { id } = Astro.params;
const hospital = await getHospital(id!);
if (!hospital) {
  return Astro.redirect(url("sykehus"));
}

const municipality = await getMunicipality(hospital.municipalityId);
const county = municipality ? await getCounty(municipality.countyId) : undefined;
const relatedHospitals = municipality
  ? (await getHospitalsByMunicipality(hospital.municipalityId))
      .filter((h) => h.id !== hospital.id)
      .slice(0, 5)
  : [];

const pageDescription = `${hospital.name} — sykehus i ${municipality?.name ?? "Norge"}, importert fra Brønnøysundregistrene og koblet i Aurii.`;

const exploreLinks = [
  ...(municipality
    ? [
        {
          title: municipality.name,
          description: "Se skoler, barnehager og postnummer i kommunen sykehuset tilhører.",
          href: url(`kommuner/${municipality.id}`),
        },
      ]
    : []),
  ...(county
    ? [
        {
          title: county.name,
          description: "Se alle kommuner i fylket.",
          href: url(`fylker/${county.id}`),
        },
      ]
    : []),
  {
    title: "Alle sykehus",
    description: "Nasjonal liste over sykehus fra Enhetsregisteret.",
    href: url("sykehus"),
  },
];
---

<Layout title={hospital.name} description={pageDescription} canonicalPath={`sykehus/${hospital.id}`}>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Sykehus", href: url("sykehus") },
      { label: hospital.name },
    ]}
  />

  <header class="mb-10">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{hospital.name}</h1>
    <p class="mt-3 flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
      Org.nr. <Badge variant="outline">{formatOrgNumber(hospital.id)}</Badge>
      {municipality && (
        <>
          · Kommune{" "}
          <a
            href={url(`kommuner/${municipality.id}`)}
            class="rounded-sm font-medium text-foreground transition-colors hover:text-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
          >
            {municipality.name}
          </a>
        </>
      )}
      {county && (
        <>
          · Fylke{" "}
          <a
            href={url(`fylker/${county.id}`)}
            class="rounded-sm font-medium text-foreground transition-colors hover:text-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
          >
            {county.name}
          </a>
        </>
      )}
    </p>
  </header>

  <section aria-labelledby="properties-heading">
    <SectionHeading
      id="properties-heading"
      title="Egenskaper"
      description="Strukturerte egenskaper importert fra Brønnøysundregistrene og validert mot Aurii-skjemaet for sykehus."
    />
    <Card class="border-border/80">
      <CardContent class="p-0">
        <Table>
          <TableBody>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Næringskode</TableCell>
              <TableCell class="text-right font-mono text-xs">{hospital.industryCode}</TableCell>
            </TableRow>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Beskrivelse</TableCell>
              <TableCell class="text-right font-medium">{hospital.industryDescription}</TableCell>
            </TableRow>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Kilde</TableCell>
              <TableCell class="text-right font-mono text-xs">{hospital.source}</TableCell>
            </TableRow>
          </TableBody>
        </Table>
      </CardContent>
    </Card>
  </section>

  {relatedHospitals.length > 0 && municipality && (
    <section class="mt-12" aria-labelledby="related-hospitals-heading">
      <SectionHeading
        id="related-hospitals-heading"
        title={`Flere sykehus i ${municipality.name}`}
        description="Andre sykehus koblet til samme kommune."
      />
      <ul class="flex flex-wrap gap-2">
        {relatedHospitals.map((related) => (
          <li>
            <a
              href={url(`sykehus/${related.id}`)}
              class="inline-flex max-w-full rounded-md border border-border/80 px-3 py-1.5 text-sm transition-colors hover:border-outline/60 hover:bg-accent/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
            >
              <span class="truncate">{related.name}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <ExploreLinks links={exploreLinks} />
</Layout>
