---
import Layout from "../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/starwind/card";
import { Table, TableBody, TableCell, TableHead, TableHeader, TableRow } from "@/components/starwind/table";
import { url } from "../lib/base";
import { formatPopulation } from "@/lib/format";
import { loadCounties, loadDatasetSummaries, loadMunicipalities, SAMPLE_QUERIES } from "../lib/data";

const counties = (await loadCounties()).sort((a, b) =>
  a.name.localeCompare(b.name, "nb"),
);
const municipalities = await loadMunicipalities();
const datasets = await loadDatasetSummaries();
const totalPopulation = municipalities.reduce((sum, m) => sum + (m.population ?? 0), 0);
const populationYear = municipalities.find((m) => m.populationYear)?.populationYear;
---

<Layout title="Offentlig referansedata">
  <div class="mb-10">
    <h1 class="text-3xl font-semibold tracking-tight">Norsk offentlig referansedata</h1>
    <p class="mt-2 text-muted-foreground">
      {datasets.length} datasett · {municipalities.length} kommuner · {formatPopulation(totalPopulation)} innbyggere
      {populationYear ? ` (per 1.1.${populationYear}, SSB)` : ""} · importert via Aurii
    </p>
  </div>

  <section class="mb-12">
    <h2 class="mb-4 text-sm font-medium uppercase tracking-wide text-muted-foreground">Datasett</h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {datasets.map((dataset) =>
        dataset.path ? (
          <a href={url(dataset.path)} class="block focus:outline-none focus-visible:ring-2 focus-visible:ring-outline rounded-lg">
            <Card class="h-full transition hover:border-outline/60 hover:bg-accent/30">
              <CardHeader>
                <div class="flex items-center justify-between gap-3">
                  <CardTitle class="text-base">{dataset.title}</CardTitle>
                  <Badge variant="outline">{dataset.count.toLocaleString("nb-NO")}</Badge>
                </div>
                <CardDescription>Kilde: {dataset.source}</CardDescription>
              </CardHeader>
            </Card>
          </a>
        ) : (
          <Card class="h-full">
            <CardHeader>
              <div class="flex items-center justify-between gap-3">
                <CardTitle class="text-base">{dataset.title}</CardTitle>
                <Badge variant="outline">{dataset.count.toLocaleString("nb-NO")}</Badge>
              </div>
              <CardDescription>Kilde: {dataset.source}</CardDescription>
            </CardHeader>
          </Card>
        ),
      )}
    </div>
  </section>

  <section class="mb-12">
    <h2 class="mb-4 text-sm font-medium uppercase tracking-wide text-muted-foreground">Fylker</h2>
    <Card>
      <CardContent class="p-0">
        <Table data-sortable>
          <TableHeader>
            <TableRow>
              <TableHead data-sort-type="text" class="w-20">Nr.</TableHead>
              <TableHead data-sort-type="text">Navn</TableHead>
              <TableHead data-sort-type="number" class="text-right">Innbyggere</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {counties.map((county) => (
              <TableRow>
                <TableCell class="font-mono text-xs text-muted-foreground" data-sort-value={county.id}>
                  {county.id}
                </TableCell>
                <TableCell>
                  <a href={url(`fylker/${county.id}`)} class="font-medium hover:text-primary">
                    {county.name}
                  </a>
                </TableCell>
                <TableCell
                  class="text-right tabular-nums"
                  data-sort-value={String(county.population ?? 0)}
                >
                  {formatPopulation(county.population)}
                </TableCell>
              </TableRow>
            ))}
          </TableBody>
        </Table>
      </CardContent>
    </Card>
  </section>

  <section>
    <h2 class="mb-2 text-sm font-medium uppercase tracking-wide text-muted-foreground">Eksempelspørringer</h2>
    <p class="mb-4 text-sm text-muted-foreground">
      Kjør i Studio eller <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs">bun run cli query</code> med dataset{" "}
      <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs">norwegian-geo</code>.
    </p>
    <Card>
      <CardContent class="p-0">
        <Table>
          <TableBody>
            {SAMPLE_QUERIES.map((query) => (
              <TableRow>
                <TableCell class="font-mono text-xs text-muted-foreground">{query}</TableCell>
              </TableRow>
            ))}
          </TableBody>
        </Table>
      </CardContent>
    </Card>
  </section>
</Layout>
