---
import Layout from "../layouts/Layout.astro";
import SearchField from "@/components/SearchField.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from "@/components/starwind/card";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/starwind/table";
import { url } from "../lib/base";
import { formatPopulation } from "@/lib/format";
import { loadCounties, loadDatasetSummaries, loadMunicipalities, SAMPLE_QUERIES } from "../lib/data";

const counties = (await loadCounties()).sort((a, b) =>
  a.name.localeCompare(b.name, "nb"),
);
const municipalities = await loadMunicipalities();
const datasets = await loadDatasetSummaries();
const totalPopulation = municipalities.reduce((sum, m) => sum + (m.population ?? 0), 0);
const populationYear = municipalities.find((m) => m.populationYear)?.populationYear;

const pipelineSteps = [
  {
    title: "Import",
    description: "Offentlige kilder importeres som strukturerte datasett i Aurii.",
  },
  {
    title: "Normaliser",
    description: "Data valideres og normaliseres mot felles skjemaer.",
  },
  {
    title: "Koble",
    description: "Fylker, kommuner, skoler og postnummer kobles gjennom relasjoner.",
  },
  {
    title: "Spørr",
    description: "Utforsk data med Aurii Query Language — samme modell som dette nettstedet.",
  },
];
---

<Layout
  title="Offentlig referansedata"
  description="Aurii Geo importerer, validerer og kobler norsk offentlig referansedata — og eksponerer den som strukturert kunnskap du kan utforske og spørre mot."
  canonicalPath=""
>
  <section class="mb-16" aria-labelledby="hero-heading">
    <div class="grid gap-10 lg:grid-cols-[1fr_280px] lg:items-start">
      <div>
        <p class="mb-3 text-sm font-medium uppercase tracking-wide text-muted-foreground">Aurii Demo</p>
        <h1 id="hero-heading" class="text-3xl font-semibold tracking-tight sm:text-4xl lg:text-[2.5rem] lg:leading-tight">
          Strukturert offentlig data bygget med Aurii
        </h1>
        <p class="mt-4 max-w-xl text-base leading-relaxed text-muted-foreground">
          Aurii importerer offentlige kilder, validerer dem mot felles skjemaer, kobler fylker, kommuner,
          skoler og postnummer gjennom relasjoner, og eksponerer resultatet som strukturert data du kan
          utforske og spørre mot.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href={url("#fylker")} size="default">
            Utforsk fylker
          </Button>
          <Button href={url("#sporringer")} variant="outline" size="default">
            Se eksempelspørringer
          </Button>
        </div>
      </div>

      <Card class="border-border/80">
        <CardHeader class="pb-3">
          <CardTitle class="text-sm font-medium text-muted-foreground">Oversikt</CardTitle>
        </CardHeader>
        <CardContent class="space-y-4 pt-0">
          <div class="flex items-baseline justify-between gap-4">
            <span class="text-sm text-muted-foreground">Datasett</span>
            <span class="text-lg font-semibold tabular-nums">{datasets.length}</span>
          </div>
          <div class="flex items-baseline justify-between gap-4">
            <span class="text-sm text-muted-foreground">Fylker</span>
            <span class="text-lg font-semibold tabular-nums">{counties.length}</span>
          </div>
          <div class="flex items-baseline justify-between gap-4">
            <span class="text-sm text-muted-foreground">Kommuner</span>
            <span class="text-lg font-semibold tabular-nums">{municipalities.length}</span>
          </div>
          <div class="border-t border-border/60 pt-4">
            <div class="flex items-baseline justify-between gap-4">
              <span class="text-sm text-muted-foreground">Befolkning</span>
              <span class="text-lg font-semibold tabular-nums">{formatPopulation(totalPopulation)}</span>
            </div>
            {populationYear && (
              <p class="mt-1 text-right text-xs text-muted-foreground">per 1.1.{populationYear} (SSB)</p>
            )}
          </div>
        </CardContent>
      </Card>
    </div>
  </section>

  <section id="datasett" class="mb-16 scroll-mt-24" aria-labelledby="datasets-heading">
    <SectionHeading
      id="datasets-heading"
      title="Datasett"
      description="Sju importerte datasett fra offentlige kilder. Hvert datasett er en entitetstype i Aurii med egne skjemaer og relasjoner til resten av modellen."
    />
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {datasets.map((dataset) =>
        dataset.path ? (
          <a
            href={url(dataset.path)}
            class="group block rounded-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
          >
            <Card class="h-full border-border/80 transition-colors group-hover:border-outline/60 group-hover:bg-accent/20">
              <CardHeader class="pb-3">
                <div class="flex items-start justify-between gap-3">
                  <CardTitle class="text-base font-semibold">{dataset.title}</CardTitle>
                  <Badge variant="outline" class="shrink-0 tabular-nums">
                    {dataset.count.toLocaleString("nb-NO")}
                  </Badge>
                </div>
                <CardDescription class="mt-2">Kilde: {dataset.source}</CardDescription>
              </CardHeader>
              <CardContent class="pt-0">
                <span class="text-sm font-medium text-primary group-hover:underline">
                  Åpne →
                </span>
              </CardContent>
            </Card>
          </a>
        ) : (
          <Card class="h-full border-border/80">
            <CardHeader class="pb-3">
              <div class="flex items-start justify-between gap-3">
                <CardTitle class="text-base font-semibold">{dataset.title}</CardTitle>
                <Badge variant="outline" class="shrink-0 tabular-nums">
                  {dataset.count.toLocaleString("nb-NO")}
                </Badge>
              </div>
              <CardDescription class="mt-2">Kilde: {dataset.source}</CardDescription>
            </CardHeader>
            <CardContent class="pt-0">
              <span class="text-sm text-muted-foreground">Utforsk i tabellen under</span>
            </CardContent>
          </Card>
        ),
      )}
    </div>
  </section>

  <section id="fylker" class="mb-16 scroll-mt-24" aria-labelledby="counties-heading">
    <SectionHeading
      id="counties-heading"
      title="Fylker"
      description="Bla gjennom norske fylker. Klikk på en kolonneoverskrift for å sortere, eller søk etter navn eller nummer."
    />
    <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <SearchField
        id="county-filter"
        label="Søk i fylker"
        placeholder="Søk etter navn eller fylkesnummer…"
        class="max-w-sm"
        data-table-filter="county-table"
      />
      <p class="text-sm text-muted-foreground" data-filter-status="county-table" data-filter-default="">
        {counties.length} fylker
      </p>
    </div>
    <Card class="border-border/80">
      <CardContent class="p-0">
        <Table id="county-table" data-sortable>
          <TableHeader>
            <TableRow class="hover:bg-transparent">
              <TableHead data-sort-type="text" class="w-20">Nr.</TableHead>
              <TableHead data-sort-type="text">Navn</TableHead>
              <TableHead data-sort-type="number" class="text-right">Innbyggere</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {counties.map((county) => (
              <TableRow class="transition-colors hover:bg-muted/50">
                <TableCell class="font-mono text-xs text-muted-foreground" data-sort-value={county.id}>
                  {county.id}
                </TableCell>
                <TableCell>
                  <a
                    href={url(`fylker/${county.id}`)}
                    class="font-medium text-foreground underline-offset-4 hover:text-primary hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-outline rounded-sm"
                  >
                    {county.name}
                  </a>
                </TableCell>
                <TableCell
                  class="text-right tabular-nums"
                  data-sort-value={String(county.population ?? 0)}
                >
                  {formatPopulation(county.population)}
                </TableCell>
              </TableRow>
            ))}
          </TableBody>
        </Table>
      </CardContent>
    </Card>
  </section>

  <section id="sporringer" class="mb-16 scroll-mt-24" aria-labelledby="queries-heading">
    <SectionHeading
      id="queries-heading"
      title="Eksempelspørringer"
      description="Disse spørringene viser hvordan du henter koblede data med Aurii Query Language. Kjør dem i Studio eller via CLI med dataset norwegian-geo."
    />
    <div class="space-y-3">
      {SAMPLE_QUERIES.map((query) => (
        <Card class="border-border/80">
          <CardContent class="flex flex-col gap-3 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
            <code class="min-w-0 flex-1 break-all font-mono text-sm text-foreground">{query}</code>
            <Button
              type="button"
              variant="outline"
              size="sm"
              class="copy-query-btn shrink-0 transition-colors duration-200"
              data-query={query}
              aria-label="Kopier spørring"
            >
              <span class="copy-query-label">Kopier</span>
            </Button>
          </CardContent>
        </Card>
      ))}
    </div>
    <p class="mt-4 text-sm text-muted-foreground">
      CLI: <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs">bun run cli query</code> med dataset{" "}
      <code class="rounded bg-muted px-1.5 py-0.5 font-mono text-xs">norwegian-geo</code>
    </p>
  </section>

  <section class="border-t border-border/60 pt-12" aria-labelledby="pipeline-heading">
    <SectionHeading
      id="pipeline-heading"
      title="Fra import til utforskning"
      description="Aurii kobler offentlige datakilder til et sammenhengende datamodell som kan spørres og presenteres."
    />
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {pipelineSteps.map((step, index) => (
        <Card class="border-border/80">
          <CardContent class="px-5 py-4">
            <span class="text-xs font-medium uppercase tracking-wide text-muted-foreground">
              {index + 1}. {step.title}
            </span>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{step.description}</p>
          </CardContent>
        </Card>
      ))}
    </div>
  </section>
</Layout>
