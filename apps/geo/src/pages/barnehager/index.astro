---
import Layout from "../../layouts/Layout.astro";
import { Card, CardContent, CardDescription } from "@/components/starwind/card";
import { Input } from "@/components/starwind/input";
import { url } from "../../lib/base";
import { loadKindergartens } from "../../lib/data";

const kindergartens = (await loadKindergartens()).sort((a, b) =>
  a.name.localeCompare(b.name, "nb"),
);
---

<Layout title="Barnehager">
  <p class="mb-3 text-sm">
    <a href={url("")} class="text-muted-foreground hover:text-foreground">← Referansedata</a>
  </p>
  <div class="mb-6">
    <h1 class="text-3xl font-semibold tracking-tight">Barnehager</h1>
    <p class="mt-2 text-muted-foreground">
      {kindergartens.length.toLocaleString("nb-NO")} barnehager fra UDIR Nasjonalt barnehageregister
    </p>
  </div>

  <div class="mb-4">
    <label for="search" class="mb-1.5 block text-sm text-muted-foreground">Søk</label>
    <Input id="search" type="search" placeholder="Barnehagenavn eller org.nr." />
  </div>

  <Card>
    <CardContent class="p-0">
      <ul id="kindergarten-list" class="divide-y divide-border">
        {kindergartens.slice(0, 100).map((kg) => (
          <li>
            <a
              href={url(`barnehager/${kg.id}`)}
              class="flex items-center justify-between px-4 py-3 transition hover:bg-accent/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
            >
              <span class="font-medium">{kg.name}</span>
              <span class="font-mono text-xs text-muted-foreground">{kg.id}</span>
            </a>
          </li>
        ))}
      </ul>
    </CardContent>
    <CardDescription id="more-note" class="px-4 py-3">
      Viser de første 100. Bruk søk for å finne en bestemt barnehage.
    </CardDescription>
  </Card>
</Layout>

<script define:vars={{ kindergartens, base: import.meta.env.BASE_URL }}>
  const input = document.getElementById("search");
  const list = document.getElementById("kindergarten-list");
  const note = document.getElementById("more-note");

  input?.addEventListener("input", () => {
    const q = input.value.trim().toLowerCase();
    if (!list) return;
    list.innerHTML = "";
    const matches = q
      ? kindergartens.filter(
          (k) =>
            k.name.toLowerCase().includes(q) || k.id.toLowerCase().includes(q),
        )
      : kindergartens.slice(0, 100);

    for (const kg of matches.slice(0, 200)) {
      const li = document.createElement("li");
      const a = document.createElement("a");
      a.href = `${base}barnehager/${kg.id}`;
      a.className =
        "flex items-center justify-between px-4 py-3 transition hover:bg-accent/30 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline";
      const name = document.createElement("span");
      name.className = "font-medium";
      name.textContent = kg.name;
      const id = document.createElement("span");
      id.className = "font-mono text-xs text-muted-foreground";
      id.textContent = kg.id;
      a.append(name, id);
      li.append(a);
      list.append(li);
    }

    if (note) {
      note.textContent = q
        ? `${matches.length} treff`
        : "Viser de første 100. Bruk søk for å finne en bestemt barnehage.";
    }
  });
</script>
