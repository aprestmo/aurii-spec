---
import Breadcrumb from "@/components/Breadcrumb.astro";
import ListPageHeader from "@/components/ListPageHeader.astro";
import SearchField from "@/components/SearchField.astro";
import ShowMoreFooter from "@/components/ShowMoreFooter.astro";
import Layout from "../../layouts/Layout.astro";
import { Card, CardContent, CardDescription } from "@/components/starwind/card";
import { formatOrgNumber } from "@/lib/format";
import { url } from "../../lib/base";
import { INITIAL_SEARCH_LIST_SIZE } from "@/lib/show-more";
import { loadKindergartens } from "../../lib/data";

const kindergartens = (await loadKindergartens()).sort((a, b) =>
  a.name.localeCompare(b.name, "nb"),
);
---

<Layout
  title="Barnehager"
  description={`${kindergartens.length.toLocaleString("nb-NO")} barnehager fra UDIR Nasjonalt barnehageregister, importert og koblet i Aurii.`}
  canonicalPath="barnehager"
>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Barnehager" },
    ]}
  />

  <ListPageHeader
    title="Barnehager"
    description={`${kindergartens.length.toLocaleString("nb-NO")} barnehager fra UDIR Nasjonalt barnehageregister, importert som strukturerte entiteter og koblet til kommune og fylke.`}
    hint="Tips: For geografisk kontekst, start på forsiden med et fylke og en kommune. Søket under finner barnehager nasjonalt etter navn eller org.nr."
  />

  <div class="mb-6">
    <SearchField
      id="search"
      label="Søk etter barnehage"
      placeholder="Barnehagenavn eller org.nr.…"
    />
  </div>

  <Card class="border-border/80">
    <CardContent class="p-0">
      <ul id="kindergarten-list" class="divide-y divide-border" data-show-more-list="kindergarten-list">
        {kindergartens.map((kg, index) => (
          <li
            class:list={[{ hidden: index >= INITIAL_SEARCH_LIST_SIZE }]}
            data-show-more-hidden={index >= INITIAL_SEARCH_LIST_SIZE ? "" : undefined}
          >
            <a
              href={url(`barnehager/${kg.id}`)}
              class="flex items-center justify-between gap-4 px-4 py-3.5 transition-colors hover:bg-muted/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
            >
              <span class="min-w-0 font-medium">{kg.name}</span>
              <span class="shrink-0 font-mono text-xs text-muted-foreground">{formatOrgNumber(kg.id)}</span>
            </a>
          </li>
        ))}
      </ul>
    </CardContent>
    <ShowMoreFooter
      listId="kindergarten-list"
      total={kindergartens.length}
      initial={INITIAL_SEARCH_LIST_SIZE}
      noun="barnehager"
    />
    <CardDescription id="more-note" class="border-t border-border/60 px-4 py-3 text-sm" role="status" aria-live="polite">
      Viser de første {INITIAL_SEARCH_LIST_SIZE.toLocaleString("nb-NO")}. Bruk søk for å finne en bestemt barnehage.
    </CardDescription>
  </Card>
</Layout>

<script is:inline define:vars={{ kindergartens, base: import.meta.env.BASE_URL, initialCount: INITIAL_SEARCH_LIST_SIZE }}>
  function formatOrgNumber(value) {
    if (!value) return "—";
    const digits = String(value).replace(/\D/g, "");
    if (digits.length !== 9) return value;
    return `${digits.slice(0, 3)} ${digits.slice(3, 6)} ${digits.slice(6, 9)}`;
  }

  const input = document.getElementById("search");
  const list = document.getElementById("kindergarten-list");
  const note = document.getElementById("more-note");
  let showAllRevealed = false;

  document.addEventListener("show-more:revealed", (event) => {
    if (event.detail.listId === "kindergarten-list") {
      showAllRevealed = true;
      if (note) note.textContent = `Viser alle ${kindergartens.length.toLocaleString("nb-NO")} barnehager.`;
    }
  });

  function renderKindergartenItem(kg) {
    const li = document.createElement("li");
    const a = document.createElement("a");
    a.href = `${base}barnehager/${kg.id}`;
    a.className =
      "flex items-center justify-between gap-4 px-4 py-3.5 transition-colors hover:bg-muted/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline";
    const name = document.createElement("span");
    name.className = "min-w-0 font-medium";
    name.textContent = kg.name;
    const id = document.createElement("span");
    id.className = "shrink-0 font-mono text-xs text-muted-foreground";
    id.textContent = formatOrgNumber(kg.id);
    a.append(name, id);
    li.append(a);
    return li;
  }

  input?.addEventListener("input", () => {
    const q = input.value.trim().toLowerCase();
    if (!list) return;

    if (!q) {
      list.innerHTML = "";
      const visible = showAllRevealed ? kindergartens : kindergartens.slice(0, initialCount);
      for (const kg of visible) {
        list.append(renderKindergartenItem(kg));
      }
      if (note) {
        note.textContent = showAllRevealed
          ? `Viser alle ${kindergartens.length.toLocaleString("nb-NO")} barnehager.`
          : `Viser de første ${initialCount.toLocaleString("nb-NO")}. Bruk søk for å finne en bestemt barnehage.`;
      }
      return;
    }

    list.innerHTML = "";
    const matches = kindergartens.filter(
      (k) => k.name.toLowerCase().includes(q) || k.id.toLowerCase().includes(q),
    );

    for (const kg of matches.slice(0, 200)) {
      list.append(renderKindergartenItem(kg));
    }

    if (note) {
      note.textContent =
        matches.length === 0
          ? "Ingen barnehager matcher søket."
          : `${matches.length.toLocaleString("nb-NO")} treff`;
    }
  });
</script>
