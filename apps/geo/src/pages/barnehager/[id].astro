---
import Breadcrumb from "@/components/Breadcrumb.astro";
import ExploreLinks from "@/components/ExploreLinks.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import Layout from "../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent } from "@/components/starwind/card";
import { Table, TableBody, TableCell, TableRow } from "@/components/starwind/table";
import { formatOrgNumber } from "@/lib/format";
import { url } from "../../lib/base";
import {
  getCounty,
  getKindergarten,
  getKindergartensByMunicipality,
  getMunicipality,
  loadKindergartens,
} from "../../lib/data";

export async function getStaticPaths() {
  const kindergartens = await loadKindergartens();
  return kindergartens.map((kg) => ({
    params: { id: kg.id },
  }));
}

const { id } = Astro.params;
const kindergarten = await getKindergarten(id!);
if (!kindergarten) {
  return Astro.redirect(url("barnehager"));
}

const municipality = await getMunicipality(kindergarten.municipalityId);
const county = await getCounty(kindergarten.countyId);
const relatedKindergartens = municipality
  ? (await getKindergartensByMunicipality(kindergarten.municipalityId))
      .filter((k) => k.id !== kindergarten.id)
      .slice(0, 5)
  : [];

const pageDescription = `${kindergarten.name} — barnehage i ${municipality?.name ?? "Norge"}, importert fra UDIR og koblet i Aurii.`;

const exploreLinks = [
  ...(municipality
    ? [
        {
          title: municipality.name,
          description: "Se alle barnehager, skoler og postnummer i kommunen.",
          href: url(`kommuner/${municipality.id}#kindergartens-heading`),
        },
      ]
    : []),
  ...(county
    ? [
        {
          title: county.name,
          description: "Se alle kommuner og nøkkeltall for fylket.",
          href: url(`fylker/${county.id}`),
        },
      ]
    : []),
  {
    title: "Søk i alle barnehager",
    description: "Nasjonal liste med søk i Nasjonalt barnehageregister.",
    href: url("barnehager"),
  },
];
---

<Layout title={kindergarten.name} description={pageDescription} canonicalPath={`barnehager/${kindergarten.id}`}>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Barnehager", href: url("barnehager") },
      { label: kindergarten.name },
    ]}
  />

  <header class="mb-10">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{kindergarten.name}</h1>
    <p class="mt-3 flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
      Org.nr. <Badge variant="outline">{formatOrgNumber(kindergarten.id)}</Badge>
      {municipality && (
        <>
          · Kommune{" "}
          <a
            href={url(`kommuner/${municipality.id}`)}
            class="rounded-sm font-medium text-foreground transition-colors hover:text-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
          >
            {municipality.name}
          </a>
        </>
      )}
      {county && (
        <>
          · Fylke{" "}
          <a
            href={url(`fylker/${county.id}`)}
            class="rounded-sm font-medium text-foreground transition-colors hover:text-primary focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
          >
            {county.name}
          </a>
        </>
      )}
    </p>
  </header>

  <section aria-labelledby="properties-heading">
    <SectionHeading
      id="properties-heading"
      title="Egenskaper"
      description="Strukturerte egenskaper importert fra UDIR og validert mot Aurii-skjemaet for barnehager."
    />
    <Card class="border-border/80">
      <CardContent class="p-0">
        <Table>
          <TableBody>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Eierform</TableCell>
              <TableCell class="text-right">
                <Badge variant="outline" size="sm">{kindergarten.isPublic ? "Offentlig" : "Privat"}</Badge>
              </TableCell>
            </TableRow>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Status</TableCell>
              <TableCell class="text-right">
                <Badge variant="outline" size="sm">{kindergarten.isActive ? "Aktiv" : "Inaktiv"}</Badge>
              </TableCell>
            </TableRow>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Kilde</TableCell>
              <TableCell class="text-right font-mono text-xs">{kindergarten.source}</TableCell>
            </TableRow>
          </TableBody>
        </Table>
      </CardContent>
    </Card>
  </section>

  {relatedKindergartens.length > 0 && municipality && (
    <section class="mt-12" aria-labelledby="related-kindergartens-heading">
      <SectionHeading
        id="related-kindergartens-heading"
        title={`Flere barnehager i ${municipality.name}`}
        description="Andre barnehager koblet til samme kommune gjennom Aurii-relasjoner."
      />
      <ul class="flex flex-wrap gap-2">
        {relatedKindergartens.map((related) => (
          <li>
            <a
              href={url(`barnehager/${related.id}`)}
              class="inline-flex max-w-full rounded-md border border-border/80 px-3 py-1.5 text-sm transition-colors hover:border-outline/60 hover:bg-accent/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
            >
              <span class="truncate">{related.name}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <ExploreLinks links={exploreLinks} />
</Layout>
