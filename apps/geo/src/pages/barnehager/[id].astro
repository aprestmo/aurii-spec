---
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import Layout from "../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent } from "@/components/starwind/card";
import { Table, TableBody, TableCell, TableRow } from "@/components/starwind/table";
import { url } from "../../lib/base";
import {
  getCounty,
  getMunicipality,
  getKindergarten,
  loadKindergartens,
} from "../../lib/data";

export async function getStaticPaths() {
  const kindergartens = await loadKindergartens();
  return kindergartens.map((kg) => ({
    params: { id: kg.id },
  }));
}

const { id } = Astro.params;
const kindergarten = await getKindergarten(id!);
if (!kindergarten) {
  return Astro.redirect(url("barnehager"));
}

const municipality = await getMunicipality(kindergarten.municipalityId);
const county = await getCounty(kindergarten.countyId);

const pageDescription = `${kindergarten.name} — barnehage i ${municipality?.name ?? "Norge"}, importert fra UDIR og koblet i Aurii.`;
---

<Layout title={kindergarten.name} description={pageDescription} canonicalPath={`barnehager/${kindergarten.id}`}>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Barnehager", href: url("barnehager") },
      { label: kindergarten.name },
    ]}
  />

  <header class="mb-10">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{kindergarten.name}</h1>
    <p class="mt-3 flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
      Org.nr. <Badge variant="outline">{kindergarten.id}</Badge>
      {municipality && (
        <>
          ·{" "}
          <a
            href={url(`kommuner/${municipality.id}`)}
            class="rounded-sm transition-colors hover:text-foreground focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
          >
            {municipality.name}
          </a>
        </>
      )}
      {county && (
        <>
          ·{" "}
          <a
            href={url(`fylker/${county.id}`)}
            class="rounded-sm transition-colors hover:text-foreground focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
          >
            {county.name}
          </a>
        </>
      )}
    </p>
  </header>

  <section aria-labelledby="properties-heading">
    <SectionHeading
      id="properties-heading"
      title="Egenskaper"
      description="Strukturerte egenskaper importert fra UDIR og validert mot Aurii-skjemaet for barnehager."
    />
    <Card class="border-border/80">
      <CardContent class="p-0">
        <Table>
          <TableBody>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Eierform</TableCell>
              <TableCell class="text-right font-medium">{kindergarten.isPublic ? "Offentlig" : "Privat"}</TableCell>
            </TableRow>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Aktiv</TableCell>
              <TableCell class="text-right font-medium">{kindergarten.isActive ? "Ja" : "Nei"}</TableCell>
            </TableRow>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Kilde</TableCell>
              <TableCell class="text-right font-mono text-xs">{kindergarten.source}</TableCell>
            </TableRow>
          </TableBody>
        </Table>
      </CardContent>
    </Card>
  </section>
</Layout>
