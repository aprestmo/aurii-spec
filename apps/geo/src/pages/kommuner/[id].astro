---
import Layout from "../../layouts/Layout.astro";
import { url } from "../../lib/base";
import {
  getCounty,
  getKindergartensByMunicipality,
  getMunicipality,
  getPostalCodesByMunicipality,
  getSchoolsByMunicipality,
  loadMunicipalities,
} from "../../lib/data";

export async function getStaticPaths() {
  const municipalities = await loadMunicipalities();
  return municipalities.map((mun) => ({
    params: { id: mun.id },
  }));
}

const { id } = Astro.params;
const municipality = await getMunicipality(id!);
if (!municipality) {
  return Astro.redirect(url(""));
}

const county = await getCounty(municipality.countyId);
const postalCodes = await getPostalCodesByMunicipality(id!, 15);
const schools = await getSchoolsByMunicipality(id!, 10);
const kindergartens = await getKindergartensByMunicipality(id!, 10);
---

<Layout title={municipality.name}>
  <p class="muted">
    <a href={url("")} style="color: var(--accent)">← Alle fylker</a>
    {county && (
      <>
        {" · "}
        <a href={url(`fylker/${county.id}`)} style="color: var(--accent)">{county.name}</a>
      </>
    )}
  </p>
  <h1>{municipality.name}</h1>
  <p class="muted">
    Kommunenummer <span class="badge">{municipality.id}</span>
    {county && (
      <> · Fylke <span class="badge">{county.name}</span></>
    )}
  </p>

  {schools.length > 0 && (
    <>
      <h2>Skoler</h2>
      <ul>
        {schools.map((school) => (
          <li>
            <a href={url(`skoler/${school.id}`)}>
              <span>{school.name}</span>
              <span class="mono">{school.isPublic ? "Offentlig" : "Privat"}</span>
            </a>
          </li>
        ))}
      </ul>
      <p class="muted"><a href={url("skoler")} style="color: var(--accent)">Søk alle skoler →</a></p>
    </>
  )}

  {kindergartens.length > 0 && (
    <>
      <h2>Barnehager</h2>
      <ul>
        {kindergartens.map((kg) => (
          <li>
            <a href={url(`barnehager/${kg.id}`)}>
              <span>{kg.name}</span>
              <span class="mono">{kg.isPublic ? "Offentlig" : "Privat"}</span>
            </a>
          </li>
        ))}
      </ul>
      <p class="muted"><a href={url("barnehager")} style="color: var(--accent)">Søk alle barnehager →</a></p>
    </>
  )}

  {postalCodes.length > 0 && (
    <>
      <h2>Postnummer ({postalCodes.length}{postalCodes.length >= 15 ? "+" : ""})</h2>
      <ul>
        {postalCodes.map((pc) => (
          <li class="row">
            <span>
              <span class="mono">{pc.code}</span> {pc.city}
            </span>
            {pc.postalCodeType && <span class="badge">{pc.postalCodeType}</span>}
          </li>
        ))}
      </ul>
    </>
  )}
</Layout>
