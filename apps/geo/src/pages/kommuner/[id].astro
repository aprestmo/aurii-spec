---
import Breadcrumb from "@/components/Breadcrumb.astro";
import EmptyState from "@/components/EmptyState.astro";
import EntityNav from "@/components/EntityNav.astro";
import FactGrid from "@/components/FactGrid.astro";
import PageHeader from "@/components/PageHeader.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import ShowMoreFooter from "@/components/ShowMoreFooter.astro";
import Layout from "../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent } from "@/components/starwind/card";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/starwind/table";
import { url } from "../../lib/base";
import { formatPercent, formatPopulation } from "@/lib/format";
import { getAdjacentMunicipalities, getRelatedMunicipalities } from "@/lib/navigation";
import { INITIAL_LIST_SIZE } from "@/lib/show-more";
import {
  getCounty,
  getCountyStats,
  getKindergartensByMunicipality,
  getMunicipality,
  getMunicipalityStats,
  getPostalCodesByMunicipality,
  getSchoolsByMunicipality,
  loadMunicipalities,
} from "../../lib/data";

export async function getStaticPaths() {
  const municipalities = await loadMunicipalities();
  return municipalities.map((mun) => ({
    params: { id: mun.id },
  }));
}

const { id } = Astro.params;
const municipality = await getMunicipality(id!);
if (!municipality) {
  return Astro.redirect(url(""));
}

const county = await getCounty(municipality.countyId);
const countyStats = county ? await getCountyStats(county.id) : undefined;
const stats = await getMunicipalityStats(id!, countyStats?.population);
const postalCodes = await getPostalCodesByMunicipality(id!);
const schools = await getSchoolsByMunicipality(id!);
const kindergartens = await getKindergartensByMunicipality(id!);
const populationYear = municipality.populationYear ?? county?.populationYear;
const adjacent = county ? await getAdjacentMunicipalities(id!, county.id) : {};
const relatedMunicipalities = county ? await getRelatedMunicipalities(id!, county.id) : [];

const pageDescription = `${municipality.name} i Aurii Geo — ${stats.schoolCount} skoler, ${stats.kindergartenCount} barnehager og ${stats.postalCodeCount} postnummer koblet gjennom Aurii-relasjoner.`;
---

<Layout title={municipality.name} description={pageDescription} canonicalPath={`kommuner/${municipality.id}`}>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      ...(county ? [{ label: county.name, href: url(`fylker/${county.id}`) }] : []),
      { label: municipality.name },
    ]}
  />

  <PageHeader title={municipality.name}>
    <Fragment slot="meta">
      Kommunenummer <Badge variant="outline">{municipality.id}</Badge>
      {county && (
        <>
          · Fylke{" "}
          <a href={url(`fylker/${county.id}`)} class="rounded-sm focus:outline-none focus-visible:ring-2 focus-visible:ring-outline">
            <Badge variant="outline">{county.name}</Badge>
          </a>
        </>
      )}
      {populationYear && (
        <>
          · Innbyggertall per 1.1.{populationYear} (SSB)
        </>
      )}
    </Fragment>
  </PageHeader>

  <FactGrid
    facts={[
      { label: "Innbyggere", value: formatPopulation(municipality.population) },
      {
        label: "Andel av fylket",
        value: formatPercent(stats.populationShareOfCounty),
      },
      { label: "Postnummer", value: String(stats.postalCodeCount) },
      { label: "Skoler", value: String(stats.schoolCount) },
      { label: "Barnehager", value: String(stats.kindergartenCount) },
      { label: "Offentlige skoler", value: String(stats.publicSchoolCount) },
      { label: "Offentlige barnehager", value: String(stats.publicKindergartenCount) },
    ]}
  />

  <div class="space-y-12">
    <section aria-labelledby="schools-heading">
      <SectionHeading
        id="schools-heading"
        title={`Skoler (${schools.length})`}
        description="Skoler registrert i kommunen via UDIR NSR og koblet til kommunen i Aurii."
      />
      {schools.length > 0 ? (
        <Card class="border-border/80">
          <CardContent class="p-0">
            <Table data-sortable>
              <TableHeader>
                <TableRow class="hover:bg-transparent">
                  <TableHead data-sort-type="text" class="w-28">Org.nr.</TableHead>
                  <TableHead data-sort-type="text">Navn</TableHead>
                  <TableHead data-sort-type="text" class="text-right">Type</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody data-show-more-list="school-list">
                {schools.map((school, index) => (
                  <TableRow
                    class:list={["transition-colors hover:bg-muted/50", { hidden: index >= INITIAL_LIST_SIZE }]}
                    data-show-more-hidden={index >= INITIAL_LIST_SIZE ? "" : undefined}
                  >
                    <TableCell class="font-mono text-xs text-muted-foreground" data-sort-value={school.id}>
                      {school.id}
                    </TableCell>
                    <TableCell>
                      <a
                        href={url(`skoler/${school.id}`)}
                        class="font-medium text-foreground underline-offset-4 hover:text-primary hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-outline rounded-sm"
                      >
                        {school.name}
                      </a>
                    </TableCell>
                    <TableCell class="text-right text-xs text-muted-foreground">
                      {school.isPublic ? "Offentlig" : "Privat"}
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </CardContent>
          <ShowMoreFooter listId="school-list" total={schools.length} noun="skoler" />
        </Card>
      ) : (
        <EmptyState>Ingen registrerte skoler ble funnet for denne kommunen.</EmptyState>
      )}
    </section>

    <section aria-labelledby="kindergartens-heading">
      <SectionHeading
        id="kindergartens-heading"
        title={`Barnehager (${kindergartens.length})`}
        description="Barnehager registrert i kommunen via UDIR NBR og koblet til kommunen i Aurii."
      />
      {kindergartens.length > 0 ? (
        <Card class="border-border/80">
          <CardContent class="p-0">
            <Table data-sortable>
              <TableHeader>
                <TableRow class="hover:bg-transparent">
                  <TableHead data-sort-type="text" class="w-28">Org.nr.</TableHead>
                  <TableHead data-sort-type="text">Navn</TableHead>
                  <TableHead data-sort-type="text" class="text-right">Type</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody data-show-more-list="kindergarten-list">
                {kindergartens.map((kg, index) => (
                  <TableRow
                    class:list={["transition-colors hover:bg-muted/50", { hidden: index >= INITIAL_LIST_SIZE }]}
                    data-show-more-hidden={index >= INITIAL_LIST_SIZE ? "" : undefined}
                  >
                    <TableCell class="font-mono text-xs text-muted-foreground" data-sort-value={kg.id}>
                      {kg.id}
                    </TableCell>
                    <TableCell>
                      <a
                        href={url(`barnehager/${kg.id}`)}
                        class="font-medium text-foreground underline-offset-4 hover:text-primary hover:underline focus:outline-none focus-visible:ring-2 focus-visible:ring-outline rounded-sm"
                      >
                        {kg.name}
                      </a>
                    </TableCell>
                    <TableCell class="text-right text-xs text-muted-foreground">
                      {kg.isPublic ? "Offentlig" : "Privat"}
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </CardContent>
          <ShowMoreFooter listId="kindergarten-list" total={kindergartens.length} noun="barnehager" />
        </Card>
      ) : (
        <EmptyState>Ingen registrerte barnehager ble funnet for denne kommunen.</EmptyState>
      )}
    </section>

    <section aria-labelledby="postal-heading">
      <SectionHeading
        id="postal-heading"
        title={`Postnummer (${postalCodes.length})`}
        description="Postnummer koblet til kommunen via Bring og Aurii-relasjoner."
      />
      {postalCodes.length > 0 ? (
        <Card class="border-border/80">
          <CardContent class="p-0">
            <Table data-sortable>
              <TableHeader>
                <TableRow class="hover:bg-transparent">
                  <TableHead data-sort-type="text" class="w-28">Postnr.</TableHead>
                  <TableHead data-sort-type="text">Poststed</TableHead>
                  <TableHead data-sort-type="text" class="text-right">Type</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody data-show-more-list="postal-list">
                {postalCodes.map((pc, index) => (
                  <TableRow
                    class:list={["transition-colors hover:bg-muted/50", { hidden: index >= INITIAL_LIST_SIZE }]}
                    data-show-more-hidden={index >= INITIAL_LIST_SIZE ? "" : undefined}
                  >
                    <TableCell class="font-mono text-xs" data-sort-value={pc.code}>
                      {pc.code}
                    </TableCell>
                    <TableCell>{pc.city}</TableCell>
                    <TableCell class="text-right">
                      {pc.postalCodeType && <Badge variant="outline">{pc.postalCodeType}</Badge>}
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </CardContent>
          <ShowMoreFooter listId="postal-list" total={postalCodes.length} noun="postnummer" />
        </Card>
      ) : (
        <EmptyState>Ingen postnummer er koblet til denne kommunen.</EmptyState>
      )}
    </section>
  </div>

  {county && relatedMunicipalities.length > 0 && (
    <section class="mt-12 border-t border-border/60 pt-8" aria-labelledby="related-heading">
      <SectionHeading
        id="related-heading"
        title={`Andre kommuner i ${county.name}`}
        description="Denne kommunen tilhører fylket gjennom en Aurii-relasjon. Utforsk nærliggende kommuner i samme fylke."
      />
      <ul class="flex flex-wrap gap-2">
        {relatedMunicipalities.map((mun) => (
          <li>
            <a
              href={url(`kommuner/${mun.id}`)}
              class="inline-flex rounded-md border border-border/80 px-3 py-1.5 text-sm transition-colors hover:border-outline/60 hover:bg-accent/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
            >
              {mun.name}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <EntityNav previous={adjacent.previous} next={adjacent.next} basePath="kommuner" label="Kommune" />
</Layout>
