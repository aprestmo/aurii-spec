---
import Layout from "../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Button } from "@/components/starwind/button";
import { Card, CardContent, CardFooter, CardHeader, CardTitle } from "@/components/starwind/card";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/starwind/table";
import { url } from "../../lib/base";
import {
  getCounty,
  getKindergartensByMunicipality,
  getMunicipality,
  getPostalCodesByMunicipality,
  getSchoolsByMunicipality,
  loadMunicipalities,
} from "../../lib/data";

export async function getStaticPaths() {
  const municipalities = await loadMunicipalities();
  return municipalities.map((mun) => ({
    params: { id: mun.id },
  }));
}

const { id } = Astro.params;
const municipality = await getMunicipality(id!);
if (!municipality) {
  return Astro.redirect(url(""));
}

const county = await getCounty(municipality.countyId);
const INITIAL_POSTAL = 20;
const postalCodes = await getPostalCodesByMunicipality(id!);
const hasMorePostal = postalCodes.length > INITIAL_POSTAL;
const schools = await getSchoolsByMunicipality(id!, 10);
const kindergartens = await getKindergartensByMunicipality(id!, 10);
---

<Layout title={municipality.name}>
  <p class="mb-3 text-sm">
    <a href={url("")} class="text-muted-foreground hover:text-foreground">← Alle fylker</a>
    {county && (
      <>
        {" · "}
        <a href={url(`fylker/${county.id}`)} class="text-muted-foreground hover:text-foreground">{county.name}</a>
      </>
    )}
  </p>
  <div class="mb-8">
    <h1 class="text-3xl font-semibold tracking-tight">{municipality.name}</h1>
    <p class="mt-2 flex items-center gap-2 text-muted-foreground">
      Kommunenummer <Badge variant="outline">{municipality.id}</Badge>
      {county && (
        <>
          · Fylke <Badge variant="outline">{county.name}</Badge>
        </>
      )}
    </p>
  </div>

  <div class="space-y-8">
    {schools.length > 0 && (
      <section>
        <Card>
          <CardHeader>
            <CardTitle class="text-base">Skoler</CardTitle>
          </CardHeader>
          <CardContent class="p-0">
            <Table>
              <TableBody>
                {schools.map((school) => (
                  <TableRow>
                    <TableCell>
                      <a href={url(`skoler/${school.id}`)} class="font-medium hover:text-primary">
                        {school.name}
                      </a>
                    </TableCell>
                    <TableCell class="text-right text-xs text-muted-foreground">
                      {school.isPublic ? "Offentlig" : "Privat"}
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </CardContent>
          <CardFooter>
            <a href={url("skoler")} class="text-sm font-medium text-primary hover:underline">Søk alle skoler →</a>
          </CardFooter>
        </Card>
      </section>
    )}

    {kindergartens.length > 0 && (
      <section>
        <Card>
          <CardHeader>
            <CardTitle class="text-base">Barnehager</CardTitle>
          </CardHeader>
          <CardContent class="p-0">
            <Table>
              <TableBody>
                {kindergartens.map((kg) => (
                  <TableRow>
                    <TableCell>
                      <a href={url(`barnehager/${kg.id}`)} class="font-medium hover:text-primary">
                        {kg.name}
                      </a>
                    </TableCell>
                    <TableCell class="text-right text-xs text-muted-foreground">
                      {kg.isPublic ? "Offentlig" : "Privat"}
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </CardContent>
          <CardFooter>
            <a href={url("barnehager")} class="text-sm font-medium text-primary hover:underline">Søk alle barnehager →</a>
          </CardFooter>
        </Card>
      </section>
    )}

    {postalCodes.length > 0 && (
      <section>
        <Card>
          <CardHeader>
            <CardTitle class="text-base">Postnummer ({postalCodes.length})</CardTitle>
          </CardHeader>
          <CardContent class="p-0">
            <Table>
              <TableHeader>
                <TableRow>
                  <TableHead>Postnummer</TableHead>
                  <TableHead>Poststed</TableHead>
                  <TableHead class="text-right">Type</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody id="postal-list">
                {postalCodes.map((pc, index) => (
                  <TableRow class:list={[{ "hidden": index >= INITIAL_POSTAL, "postal-hidden-row": index >= INITIAL_POSTAL }]}>
                    <TableCell class="font-mono text-xs">{pc.code}</TableCell>
                    <TableCell>{pc.city}</TableCell>
                    <TableCell class="text-right">
                      {pc.postalCodeType && <Badge variant="outline">{pc.postalCodeType}</Badge>}
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </CardContent>
          {hasMorePostal && (
            <CardFooter>
              <Button type="button" variant="outline" size="sm" id="postal-show-more">
                Vis alle {postalCodes.length} postnummer
              </Button>
            </CardFooter>
          )}
        </Card>
      </section>
    )}
  </div>

  {hasMorePostal && (
    <script>
      document.getElementById("postal-show-more")?.addEventListener("click", (event) => {
        document
          .querySelectorAll<HTMLElement>("#postal-list .postal-hidden-row")
          .forEach((row) => row.classList.remove("hidden"));
        (event.currentTarget as HTMLElement)?.remove();
      });
    </script>
  )}
</Layout>
