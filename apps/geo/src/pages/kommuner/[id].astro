---
import ShowMoreFooter from "@/components/ShowMoreFooter.astro";
import Layout from "../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/starwind/card";
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/starwind/table";
import { url } from "../../lib/base";
import { INITIAL_LIST_SIZE } from "@/lib/show-more";
import {
  getCounty,
  getKindergartensByMunicipality,
  getMunicipality,
  getPostalCodesByMunicipality,
  getSchoolsByMunicipality,
  loadMunicipalities,
} from "../../lib/data";

export async function getStaticPaths() {
  const municipalities = await loadMunicipalities();
  return municipalities.map((mun) => ({
    params: { id: mun.id },
  }));
}

const { id } = Astro.params;
const municipality = await getMunicipality(id!);
if (!municipality) {
  return Astro.redirect(url(""));
}

const county = await getCounty(municipality.countyId);
const postalCodes = await getPostalCodesByMunicipality(id!);
const schools = await getSchoolsByMunicipality(id!);
const kindergartens = await getKindergartensByMunicipality(id!);
---

<Layout title={municipality.name}>
  <p class="mb-3 text-sm">
    <a href={url("")} class="text-muted-foreground hover:text-foreground">← Alle fylker</a>
    {county && (
      <>
        {" · "}
        <a href={url(`fylker/${county.id}`)} class="text-muted-foreground hover:text-foreground">{county.name}</a>
      </>
    )}
  </p>
  <div class="mb-8">
    <h1 class="text-3xl font-semibold tracking-tight">{municipality.name}</h1>
    <p class="mt-2 flex items-center gap-2 text-muted-foreground">
      Kommunenummer <Badge variant="outline">{municipality.id}</Badge>
      {county && (
        <>
          · Fylke <Badge variant="outline">{county.name}</Badge>
        </>
      )}
    </p>
  </div>

  <div class="space-y-8">
    {schools.length > 0 && (
      <section>
        <Card>
          <CardHeader>
            <CardTitle class="text-base">Skoler ({schools.length})</CardTitle>
          </CardHeader>
          <CardContent class="p-0">
            <Table>
              <TableBody data-show-more-list="school-list">
                {schools.map((school, index) => (
                  <TableRow
                    class:list={[{ hidden: index >= INITIAL_LIST_SIZE }]}
                    data-show-more-hidden={index >= INITIAL_LIST_SIZE ? "" : undefined}
                  >
                    <TableCell>
                      <a href={url(`skoler/${school.id}`)} class="font-medium hover:text-primary">
                        {school.name}
                      </a>
                    </TableCell>
                    <TableCell class="text-right text-xs text-muted-foreground">
                      {school.isPublic ? "Offentlig" : "Privat"}
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </CardContent>
          <ShowMoreFooter listId="school-list" total={schools.length} noun="skoler" />
        </Card>
      </section>
    )}

    {kindergartens.length > 0 && (
      <section>
        <Card>
          <CardHeader>
            <CardTitle class="text-base">Barnehager ({kindergartens.length})</CardTitle>
          </CardHeader>
          <CardContent class="p-0">
            <Table>
              <TableBody data-show-more-list="kindergarten-list">
                {kindergartens.map((kg, index) => (
                  <TableRow
                    class:list={[{ hidden: index >= INITIAL_LIST_SIZE }]}
                    data-show-more-hidden={index >= INITIAL_LIST_SIZE ? "" : undefined}
                  >
                    <TableCell>
                      <a href={url(`barnehager/${kg.id}`)} class="font-medium hover:text-primary">
                        {kg.name}
                      </a>
                    </TableCell>
                    <TableCell class="text-right text-xs text-muted-foreground">
                      {kg.isPublic ? "Offentlig" : "Privat"}
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </CardContent>
          <ShowMoreFooter listId="kindergarten-list" total={kindergartens.length} noun="barnehager" />
        </Card>
      </section>
    )}

    {postalCodes.length > 0 && (
      <section>
        <Card>
          <CardHeader>
            <CardTitle class="text-base">Postnummer ({postalCodes.length})</CardTitle>
          </CardHeader>
          <CardContent class="p-0">
            <Table>
              <TableHeader>
                <TableRow>
                  <TableHead>Postnummer</TableHead>
                  <TableHead>Poststed</TableHead>
                  <TableHead class="text-right">Type</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody data-show-more-list="postal-list">
                {postalCodes.map((pc, index) => (
                  <TableRow
                    class:list={[{ hidden: index >= INITIAL_LIST_SIZE }]}
                    data-show-more-hidden={index >= INITIAL_LIST_SIZE ? "" : undefined}
                  >
                    <TableCell class="font-mono text-xs">{pc.code}</TableCell>
                    <TableCell>{pc.city}</TableCell>
                    <TableCell class="text-right">
                      {pc.postalCodeType && <Badge variant="outline">{pc.postalCodeType}</Badge>}
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </CardContent>
          <ShowMoreFooter listId="postal-list" total={postalCodes.length} noun="postnummer" />
        </Card>
      </section>
    )}
  </div>
</Layout>
