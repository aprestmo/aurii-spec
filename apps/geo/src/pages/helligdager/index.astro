---
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import Layout from "../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent } from "@/components/starwind/card";
import { Table, TableBody, TableCell, TableRow } from "@/components/starwind/table";
import { url } from "../../lib/base";
import { loadPublicHolidays } from "../../lib/data";

const holidays = (await loadPublicHolidays()).sort((a, b) =>
  a.date.localeCompare(b.date),
);
const years = [...new Set(holidays.map((h) => h.year))].sort();
---

<Layout
  title="Helligdager"
  description={`${holidays.length} norske helligdager (${years[0]}–${years[years.length - 1]}) importert og strukturert i Aurii.`}
  canonicalPath="helligdager"
>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Helligdager" },
    ]}
  />

  <header class="mb-10">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Helligdager</h1>
    <p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
      {holidays.length} helligdager ({years[0]}–{years[years.length - 1]}) avledet fra Helligdagsloven
      via Nager.Date og importert som strukturerte entiteter i Aurii.
    </p>
  </header>

  <div class="space-y-10">
    {years.map((year) => (
      <section aria-labelledby={`year-${year}`}>
        <SectionHeading id={`year-${year}`} title={String(year)} />
        <Card class="border-border/80">
          <CardContent class="p-0">
            <Table>
              <TableBody>
                {holidays
                  .filter((h) => h.year === year)
                  .map((holiday) => (
                    <TableRow class="transition-colors hover:bg-muted/50">
                      <TableCell class="w-28 font-mono text-xs text-muted-foreground">{holiday.date}</TableCell>
                      <TableCell class="font-medium">{holiday.localName}</TableCell>
                      <TableCell class="text-right">
                        {holiday.holidayType && <Badge variant="outline">{holiday.holidayType}</Badge>}
                      </TableCell>
                    </TableRow>
                  ))}
              </TableBody>
            </Table>
          </CardContent>
        </Card>
      </section>
    ))}
  </div>
</Layout>
