---
import Breadcrumb from "@/components/Breadcrumb.astro";
import ExploreLinks from "@/components/ExploreLinks.astro";
import ListPageHeader from "@/components/ListPageHeader.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import TableScroll from "@/components/TableScroll.astro";
import Layout from "../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent } from "@/components/starwind/card";
import { Table, TableBody, TableCaption, TableCell, TableRow } from "@/components/starwind/table";
import { url } from "../../lib/base";
import { loadPublicHolidays } from "../../lib/data";

const holidays = (await loadPublicHolidays()).sort((a, b) =>
  a.date.localeCompare(b.date),
);
const years = [...new Set(holidays.map((h) => h.year))].sort();
---

<Layout
  title="Helligdager"
  description={`${holidays.length} norske helligdager (${years[0]}–${years[years.length - 1]}) importert og strukturert i Aurii.`}
  canonicalPath="helligdager"
>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Helligdager" },
    ]}
  />

  <ListPageHeader
    title="Helligdager"
    description={`${holidays.length} helligdager (${years[0]}–${years[years.length - 1]}) avledet fra Helligdagsloven via Nager.Date og importert som strukturerte entiteter.`}
    hint="Dette datasettet er nasjonalt og ikke geografisk koblet — det viser at Aurii også håndterer kalenderdata utenfor fylke→kommune-hierarkiet."
  />

  <div class="space-y-10">
    {years.map((year) => (
      <section aria-labelledby={`year-${year}`}>
        <SectionHeading id={`year-${year}`} title={String(year)} />
        <Card class="border-border/80">
          <CardContent class="p-0">
            <TableScroll>
              <Table>
                <TableCaption class="sr-only">Helligdager i {year}</TableCaption>
                <TableBody>
                  {holidays
                    .filter((h) => h.year === year)
                    .map((holiday) => (
                      <TableRow class="transition-colors hover:bg-muted/50">
                        <TableCell class="w-28 font-mono text-xs text-muted-foreground">{holiday.date}</TableCell>
                        <TableCell class="font-medium">{holiday.localName}</TableCell>
                        <TableCell class="hidden text-sm text-muted-foreground sm:table-cell">{holiday.name}</TableCell>
                        <TableCell class="text-right">
                          {holiday.holidayType && <Badge variant="outline">{holiday.holidayType}</Badge>}
                        </TableCell>
                      </TableRow>
                    ))}
                </TableBody>
              </Table>
            </TableScroll>
          </CardContent>
        </Card>
      </section>
    ))}
  </div>

  <ExploreLinks
    links={[
      {
        title: "Geografiske datasett",
        description: "Se hvordan fylker, kommuner og registre henger sammen.",
        href: url("#datasett"),
      },
      {
        title: "Eksempelspørringer",
        description: "Hent helligdager med Aurii Query Language.",
        href: url("#sporringer"),
      },
    ]}
  />
</Layout>
