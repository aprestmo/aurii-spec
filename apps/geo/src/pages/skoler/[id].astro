---
import Breadcrumb from "@/components/Breadcrumb.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import Layout from "../../layouts/Layout.astro";
import { Badge } from "@/components/starwind/badge";
import { Card, CardContent } from "@/components/starwind/card";
import { Table, TableBody, TableCell, TableRow } from "@/components/starwind/table";
import { url } from "../../lib/base";
import {
  getCounty,
  getMunicipality,
  getSchool,
  loadSchools,
} from "../../lib/data";

export async function getStaticPaths() {
  const schools = await loadSchools();
  return schools.map((school) => ({
    params: { id: school.id },
  }));
}

const { id } = Astro.params;
const school = await getSchool(id!);
if (!school) {
  return Astro.redirect(url("skoler"));
}

const municipality = await getMunicipality(school.municipalityId);
const county = await getCounty(school.countyId);

const pageDescription = `${school.name} — skole i ${municipality?.name ?? "Norge"}, importert fra UDIR og koblet i Aurii.`;
---

<Layout title={school.name} description={pageDescription} canonicalPath={`skoler/${school.id}`}>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Skoler", href: url("skoler") },
      { label: school.name },
    ]}
  />

  <header class="mb-10">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">{school.name}</h1>
    <p class="mt-3 flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
      Org.nr. <Badge variant="outline">{school.id}</Badge>
      {municipality && (
        <>
          ·{" "}
          <a
            href={url(`kommuner/${municipality.id}`)}
            class="rounded-sm transition-colors hover:text-foreground focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
          >
            {municipality.name}
          </a>
        </>
      )}
      {county && (
        <>
          ·{" "}
          <a
            href={url(`fylker/${county.id}`)}
            class="rounded-sm transition-colors hover:text-foreground focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
          >
            {county.name}
          </a>
        </>
      )}
    </p>
  </header>

  <section aria-labelledby="properties-heading">
    <SectionHeading
      id="properties-heading"
      title="Egenskaper"
      description="Strukturerte egenskaper importert fra UDIR og validert mot Aurii-skjemaet for skoler."
    />
    <Card class="border-border/80">
      <CardContent class="p-0">
        <Table>
          <TableBody>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Type</TableCell>
              <TableCell class="text-right font-medium">
                {school.isPrimary ? "Grunnskole" : school.isSecondary ? "Videregående" : "Annet"}
              </TableCell>
            </TableRow>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Eierform</TableCell>
              <TableCell class="text-right font-medium">{school.isPublic ? "Offentlig" : "Privat"}</TableCell>
            </TableRow>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Aktiv</TableCell>
              <TableCell class="text-right font-medium">{school.isActive ? "Ja" : "Nei"}</TableCell>
            </TableRow>
            <TableRow class="transition-colors hover:bg-muted/50">
              <TableCell class="text-muted-foreground">Kilde</TableCell>
              <TableCell class="text-right font-mono text-xs">{school.source}</TableCell>
            </TableRow>
          </TableBody>
        </Table>
      </CardContent>
    </Card>
  </section>
</Layout>
