---
import Breadcrumb from "@/components/Breadcrumb.astro";
import ListPageHeader from "@/components/ListPageHeader.astro";
import SearchField from "@/components/SearchField.astro";
import ShowMoreFooter from "@/components/ShowMoreFooter.astro";
import Layout from "../../layouts/Layout.astro";
import { Card, CardContent, CardDescription } from "@/components/starwind/card";
import { formatOrgNumber } from "@/lib/format";
import { url } from "../../lib/base";
import { INITIAL_SEARCH_LIST_SIZE } from "@/lib/show-more";
import { loadSchools } from "../../lib/data";

const schools = (await loadSchools()).sort((a, b) =>
  a.name.localeCompare(b.name, "nb"),
);
---

<Layout
  title="Skoler"
  description={`${schools.length.toLocaleString("nb-NO")} skoler fra UDIR Nasjonalt skoleregister, importert og koblet i Aurii.`}
  canonicalPath="skoler"
>
  <Breadcrumb
    items={[
      { label: "Forside", href: url("") },
      { label: "Skoler" },
    ]}
  />

  <ListPageHeader
    title="Skoler"
    description={`${schools.length.toLocaleString("nb-NO")} skoler fra UDIR Nasjonalt skoleregister, importert som strukturerte entiteter og koblet til kommune og fylke.`}
    hint="Tips: Kjenner du kommunen? Start med et fylke på forsiden og gå videre til kommunen for å se alle skoler der. Bruk søket under for å finne en bestemt skole nasjonalt."
  />

  <div class="mb-6">
    <SearchField
      id="search"
      label="Søk etter skole"
      placeholder="Skolenavn eller org.nr.…"
    />
  </div>

  <Card class="border-border/80">
    <CardContent class="p-0">
      <ul id="school-list" class="divide-y divide-border" data-show-more-list="school-list">
        {schools.map((school, index) => (
          <li
            data-name={school.name.toLowerCase()}
            data-id={school.id}
            class:list={[{ hidden: index >= INITIAL_SEARCH_LIST_SIZE }]}
            data-show-more-hidden={index >= INITIAL_SEARCH_LIST_SIZE ? "" : undefined}
          >
            <a
              href={url(`skoler/${school.id}`)}
              class="flex items-center justify-between gap-4 px-4 py-3.5 transition-colors hover:bg-muted/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline"
            >
              <span class="min-w-0 font-medium">{school.name}</span>
              <span class="shrink-0 font-mono text-xs text-muted-foreground">{formatOrgNumber(school.id)}</span>
            </a>
          </li>
        ))}
      </ul>
    </CardContent>
    <ShowMoreFooter
      listId="school-list"
      total={schools.length}
      initial={INITIAL_SEARCH_LIST_SIZE}
      noun="skoler"
    />
    <CardDescription id="more-note" class="border-t border-border/60 px-4 py-3 text-sm" role="status" aria-live="polite">
      Viser de første {INITIAL_SEARCH_LIST_SIZE.toLocaleString("nb-NO")}. Bruk søk for å finne en bestemt skole.
    </CardDescription>
  </Card>
</Layout>

<script is:inline define:vars={{ schools, base: import.meta.env.BASE_URL, initialCount: INITIAL_SEARCH_LIST_SIZE }}>
  function formatOrgNumber(value) {
    if (!value) return "—";
    const digits = String(value).replace(/\D/g, "");
    if (digits.length !== 9) return value;
    return `${digits.slice(0, 3)} ${digits.slice(3, 6)} ${digits.slice(6, 9)}`;
  }

  const input = document.getElementById("search");
  const list = document.getElementById("school-list");
  const note = document.getElementById("more-note");
  let showAllRevealed = false;

  document.addEventListener("show-more:revealed", (event) => {
    if (event.detail.listId === "school-list") {
      showAllRevealed = true;
      if (note) note.textContent = `Viser alle ${schools.length.toLocaleString("nb-NO")} skoler.`;
    }
  });

  function renderSchoolItem(school) {
    const li = document.createElement("li");
    li.dataset.name = school.name.toLowerCase();
    li.dataset.id = school.id;
    const a = document.createElement("a");
    a.href = `${base}skoler/${school.id}`;
    a.className =
      "flex items-center justify-between gap-4 px-4 py-3.5 transition-colors hover:bg-muted/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-outline";
    const name = document.createElement("span");
    name.className = "min-w-0 font-medium";
    name.textContent = school.name;
    const id = document.createElement("span");
    id.className = "shrink-0 font-mono text-xs text-muted-foreground";
    id.textContent = formatOrgNumber(school.id);
    a.append(name, id);
    li.append(a);
    return li;
  }

  input?.addEventListener("input", () => {
    const q = input.value.trim().toLowerCase();
    if (!list) return;

    if (!q) {
      list.innerHTML = "";
      const visible = showAllRevealed ? schools : schools.slice(0, initialCount);
      for (const school of visible) {
        list.append(renderSchoolItem(school));
      }
      if (note) {
        note.textContent = showAllRevealed
          ? `Viser alle ${schools.length.toLocaleString("nb-NO")} skoler.`
          : `Viser de første ${initialCount.toLocaleString("nb-NO")}. Bruk søk for å finne en bestemt skole.`;
      }
      return;
    }

    list.innerHTML = "";
    const matches = schools.filter(
      (s) => s.name.toLowerCase().includes(q) || s.id.toLowerCase().includes(q),
    );

    for (const school of matches.slice(0, 200)) {
      list.append(renderSchoolItem(school));
    }

    if (note) {
      note.textContent =
        matches.length === 0
          ? "Ingen skoler matcher søket."
          : `${matches.length.toLocaleString("nb-NO")} treff`;
    }
  });
</script>
