---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Schemas" active="schemas">
  <h1>Schemas</h1>
  <p class="subtitle">Registered schemas in this dataset.</p>

  <div id="schema-list" class="grid cols-3">
    <p class="muted">Loading…</p>
  </div>

  <script>
    import { getClient } from "../lib/client";
    import { getDataset } from "../lib/api";

    const ds = getDataset();
    const list = document.getElementById("schema-list")!;

    try {
      const client = getClient();
      const schemas = await client.schemas.list(ds);
      if (schemas.length === 0) {
        list.innerHTML = `<p class="muted">No schemas yet. Import data to create one.</p>`;
      } else {
        list.innerHTML = schemas.map((s) => `
          <div class="card">
            <div class="flex" style="margin-bottom: 8px;">
              <strong>${s.name}</strong>
              <span class="badge info right">${new Date(s.updatedAt).toLocaleDateString()}</span>
            </div>
            <p class="muted mono" style="margin-bottom: 12px;">${s.id}</p>
            ${s.description ? `<p class="muted" style="margin-bottom: 12px;">${s.description}</p>` : ""}
            <table>
              <tbody>
                ${s.fields.map((f) => `
                  <tr>
                    <td class="mono">${f.name}${f.required ? " *" : ""}</td>
                    <td style="text-align:right"><span class="badge info">${f.type}</span></td>
                  </tr>`).join("")}
              </tbody>
            </table>
          </div>`).join("");
      }
    } catch (e) {
      list.innerHTML = `<div class="error-box">${String(e)}</div>`;
    }
  </script>
</Layout>
